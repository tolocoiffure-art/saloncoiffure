---
import TermsContent from './terms.content.md';
import { resolveTenantFromRequest } from '~/lib/tenants';
import { resolveTonSiteWebComponent } from '~/tenants/tonsiteweb/router';

const tenant = resolveTenantFromRequest(Astro.request);

const TonComponent =
  tenant.slug === 'tonsiteweb'
    ? resolveTonSiteWebComponent('terms', Astro.url instanceof URL ? Astro.url : new URL(Astro.request.url), Astro.request)
    : null;
---

{TonComponent ? <TonComponent /> : <TermsContent />}
