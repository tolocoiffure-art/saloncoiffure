      tone: 'light',
    },
    info: {
      title: lceT('Ce que nous verrouillons', 'What we lock in', 'Was wir fixieren', 'Cosa blocchiamo', 'ما الذي نثبته', '我们为您锁定什么'),
      subtitle: lceT(
        'Itinéraires, partenaires, transferts.',
        'Itineraries, partners, transfers.',
        'Routen, Partner, Transfers.',
        'Itinerari, partner, transfer.',
        'المسارات، الشركاء، التنقلات.',
        '行程、伙伴、接驳。'
      ),
