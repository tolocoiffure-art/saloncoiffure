      callToAction: `<a class="btn btn-primary" href="/contact#form">${lamT('Réserver ma date', 'Reserve my date', 'Datum reservieren', 'Prenota la data')}</a>`,
    },
    {
      title: lamT('2–3 pièces', '2–3 rooms', '2–3 Zimmer', '2–3 locali'),
      subtitle: '~20 m³',
      price: '800–1300',
      period: lamT('déménagement local', 'local move', 'lokaler Umzug', 'trasloco locale'),
      items: [
        {
          description: lamT(
            '800 CHF = déménagement propre en ~2.5–3h.',
            '800 CHF = clean move in ~2.5–3h.',
            '800 CHF = sauberer Umzug in ~2.5–3h.',
            '800 CHF = trasloco pulito in ~2.5–3h.'
          ),
        },
        {
          description: lamT(
            '1300 CHF = 4–5h avec complexité d’accès/logistique.',
            '1300 CHF = 4–5h with access/logistics complexity.',
            '1300 CHF = 4–5h mit Zugangs-/Logistikkomplexität.',
            '1300 CHF = 4–5h con complessità di accesso/logistica.'
          ),
        },
        {
          description: lamT(
            'Positionnement fort avec marge saine.',
            'Strong positioning with healthy margin.',
            'Starke Positionierung mit gesunder Marge.',
            'Posizionamento forte con margine sano.'
          ),
        },
      ],
      hasRibbon: true,
      ribbonTitle: lamT('Le plus demandé', 'Most requested', 'Am meisten gefragt', 'Il più richiesto'),
      callToAction: `<a class="btn btn-primary" href="/contact#form">${lamT('Réserver ma date', 'Reserve my date', 'Datum reservieren', 'Prenota la data')}</a>`,
    },
    {
      title: lamT('3–4 pièces', '3–4 rooms', '3–4 Zimmer', '3–4 locali'),
      subtitle: '~30–35 m³',
      price: '1200–1700',
      period: lamT('déménagement local', 'local move', 'lokaler Umzug', 'trasloco locale'),
      items: [
        {
          description: lamT(
            'Fourchette actuelle 1100–1450 CHF: positionnement prudent.',
            'Current 1100–1450 CHF range: conservative positioning.',
            'Aktuelle Spanne 1100–1450 CHF: konservative Positionierung.',
            'Fascia attuale 1100–1450 CHF: posizionamento prudente.'
          ),
        },
        {
          description: lamT(
            'Selon accès complexes, le marché peut monter vers 1700 CHF.',
            'With complex access, market pricing can rise toward 1700 CHF.',
            'Bei komplexem Zugang kann der Markt Richtung 1700 CHF gehen.',
            'Con accessi complessi, il mercato può salire verso 1700 CHF.'
          ),
        },
        {
          description: lamT(
            'Niveau tarifaire solide et défendable.',
            'Solid and defensible pricing level.',
            'Solides und verteidigbares Preisniveau.',
            'Livello tariffario solido e difendibile.'
          ),
        },
      ],
      callToAction: `<a class="btn btn-primary" href="/contact#form">${lamT('Réserver ma date', 'Reserve my date', 'Datum reservieren', 'Prenota la data')}</a>`,
    },
    {
      title: lamT('Maison / 5 pièces +', 'House / 5 rooms +', 'Haus / 5 Zimmer +', 'Casa / 5 locali +'),
      subtitle: '40–45 m³+',
      price: '1500–2500',
      period: lamT('déménagement local', 'local move', 'lokaler Umzug', 'trasloco locale'),
      items: [
        {
          description: lamT(
            '1500–2500 CHF: positionnement professionnel solide.',
            '1500–2500 CHF: solid professional positioning.',
            '1500–2500 CHF: solide professionelle Positionierung.',
            '1500–2500 CHF: posizionamento professionale solido.'
          ),
        },
        {
          description: lamT(
            'Ni low-cost, ni ultra-luxe: équilibre sain.',
            'Neither low-cost nor ultra-luxury: healthy balance.',
            'Weder Low-Cost noch Ultra-Luxus: gesunde Balance.',
            'Né low-cost né ultra-lusso: equilibrio sano.'
          ),
        },
        {
          description: lamT(
            'Ajustement final selon volume réel, temps et accès.',
            'Final adjustment based on real volume, time, and access.',
            'Finale Anpassung nach Realvolumen, Zeit und Zugang.',
            'Adeguamento finale su volume reale, tempo e accessi.'
          ),
        },
      ],
      callToAction: `<a class="btn btn-primary" href="/contact#form">${lamT('Demander un devis', 'Request a quote', 'Offerte anfragen', 'Richiedi un preventivo')}</a>`,
    },
  ];
})();
const experienceFaqTitle = isExperience
  ? lceT(
      'Questions sur les tarifs',
      'Pricing questions',
      'Fragen zu den Preisen',
      'Domande sui prezzi',
      'أسئلة حول الأسعار',
      '价格问答'
    )
  : `Questions sur les tarifs ${view.hero.tagline?.toLowerCase?.() || ''}`.trim();
const toneStrong = view.hero.tone === 'dark' ? 'text-white' : 'text-slate-900';
const toneMuted = view.hero.tone === 'dark' ? 'text-white/85' : 'text-slate-600';
---

{
  TonComponent ? (
    <TonComponent />
  ) : (
    <Layout metadata={metadata}>
      <section
        class={`relative overflow-hidden brand-${brandKey} ${heroToneClass}`}
        style={`background-image:${isUrgentPricing ? 'none' : view.hero.background}; background-size: cover; background-position: center;`}
      >
        <div class={`absolute inset-0 ${isUrgentPricing ? 'bg-white' : view.hero.overlayClass}`} />
        <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-14 md:py-18 space-y-8">
          <div class="flex flex-wrap gap-3">
            {view.hero.chips.map((chip) => (
              <span
                class={`hero-chip rounded-full px-4 py-2 text-sm font-semibold ${
                  isEtat
                    ? 'bg-white border border-slate-200 text-slate-900'
                    : 'bg-white/15 border border-white/20 text-white backdrop-blur'
                }`}
              >
                {chip}
              </span>
            ))}
          </div>
          <div class="grid gap-10 md:grid-cols-[1fr_1fr] lg:grid-cols-[0.95fr_1.05fr] items-start">
            <div class="space-y-5">
              <p class={`text-sm uppercase tracking-[0.32em] ${toneMuted}`}>{view.hero.tagline}</p>
              <h1 class={`text-3xl md:text-4xl font-semibold leading-snug ${toneStrong}`}>{view.hero.title}</h1>
              <p class={`text-lg md:text-lg max-w-3xl ${toneMuted}`}>{view.hero.subtitle}</p>
            </div>
            <div class="relative">
              <div class={`absolute -inset-6 blur-3xl opacity-70 bg-gradient-to-br ${view.accent}`} />
              <div
                class={`relative rounded-3xl backdrop-blur-lg shadow-2xl p-8 space-y-3 ${
                  isEtat
                    ? 'border border-slate-200/70 bg-white/92 text-slate-900'
                    : 'border border-white/20 bg-white/10 text-white'
                }`}
              >
                <p class={`text-xs uppercase tracking-[0.3em] ${isEtat ? 'text-slate-500' : 'text-white/70'}`}>
                  Repères rapides
                </p>
                <p class="text-2xl font-semibold">{view.priceTitle}</p>
                <p class={`${isEtat ? 'text-slate-700' : 'text-white/85'} text-base leading-relaxed`}>
                  {view.priceSubtitle}
                </p>
                <div
                  class={`grid sm:grid-cols-[0.85fr_1.15fr] gap-3 pt-2 text-xs sm:text-sm ${
                    isEtat ? 'text-slate-700' : 'text-white/85'
                  }`}
                >
                  <div
                    class={`rounded-xl px-3 py-2 ${
                      isEtat ? 'border border-slate-200 bg-white' : 'border border-white/15 bg-white/10'
                    }`}
                  >
                    Téléphone
                    <br />
                    <span class={`${isEtat ? 'text-slate-900' : 'text-white'} font-semibold block whitespace-nowrap`}>
                      {brand.phone}
                    </span>
                  </div>
                  <div
                    class={`rounded-xl px-3 py-2 ${
                      isEtat ? 'border border-slate-200 bg-white' : 'border border-white/15 bg-white/10'
                    }`}
                  >
                    Email
                    <br />
                    <span class={`${isEtat ? 'text-slate-900' : 'text-white'} font-semibold block whitespace-nowrap`}>
                      {brand.email}
                    </span>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </section>

      <section class="relative py-14 md:py-18 bg-gradient-to-b from-white/90 via-white/95 to-white dark:from-slate-950/60 dark:via-slate-950/65 dark:to-slate-950/60">
        <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
          {isLausanne ? (
            <div class="lausanne-tabs">
              <input
                class="lausanne-tab-switch"
                id="lausanne-tab-pricing"
                type="radio"
                name="lausanne-pricing-tabs"
                checked
              />
              <input class="lausanne-tab-switch" id="lausanne-tab-robot" type="radio" name="lausanne-pricing-tabs" />
              <p class="lausanne-tab-hint">
                {lamT('Basculer l’affichage', 'Switch view', 'Ansicht wechseln', 'Cambia vista')}
              </p>
              <div class="lausanne-tab-controls">
                <label for="lausanne-tab-pricing">
                  {lamT('Repères déménagement', 'Moving anchors', 'Umzugs-Referenzen', 'Riferimenti trasloco')}
                </label>
                <label for="lausanne-tab-robot">
                  {lamT('Calendly robot', 'Robot Calendly', 'Robot Calendly', 'Calendly robot')}
                </label>
              </div>
              <div class="lausanne-tab-panels">
                <div class="lausanne-tab-panel pricing-panel">
                  <div class="space-y-8 md:space-y-10">
                    <div class="relative">
                      <div class="absolute -inset-4 blur-3xl opacity-60 bg-white/60 dark:bg-slate-900/40" />
                      <div class="relative rounded-3xl shadow-2xl border border-slate-200/80 dark:border-slate-800/70 bg-white/95 dark:bg-slate-900/90 pricing-card">
                        <Prices
                          title={view.priceTitle}
                          subtitle={view.priceSubtitle}
                          prices={priceList}
                          columns={isEtat ? 2 : 3}
                          classes={{ container: 'max-w-full md:px-8' }}
                        />
                      </div>
                    </div>
                    <div class="rounded-3xl border border-slate-200/70 dark:border-slate-800/70 bg-white/85 dark:bg-slate-900/85 shadow-xl p-8 md:p-10 space-y-4">
                      <p class="text-sm uppercase tracking-[0.28em] text-slate-500 dark:text-slate-300">
                        Comment on calcule
                      </p>
                      <h3 class="text-2xl md:text-3xl font-semibold text-slate-900 dark:text-white">
                        {view.priceTitle}
                      </h3>
                      <p class="text-slate-600 dark:text-slate-300">{view.priceSubtitle}</p>
                      <div class="space-y-3">
                        {view.factors.slice(0, 3).map((item) => (
                          <div class="p-4 rounded-2xl border border-slate-200/80 dark:border-slate-800/80 bg-slate-50/80 dark:bg-white/5 shadow-sm">
                            <p class="text-base font-semibold text-slate-900 dark:text-white">{item.title}</p>
                            <p class="text-slate-600 dark:text-slate-300 text-sm mt-1">{item.description}</p>
                          </div>
                        ))}
                      </div>
                    </div>
                  </div>
                </div>
                <div class="lausanne-tab-panel robot-panel">
                  <div class="rounded-3xl border border-slate-200/80 dark:border-slate-800/70 bg-white dark:bg-slate-900 shadow-xl p-6 md:p-8">
                    <div class="grid gap-6 lg:grid-cols-[0.85fr_1.15fr] items-start">
                      <div class="space-y-3">
                        <p class="text-xs uppercase tracking-[0.3em] text-slate-500">
                          {lamT('Location dédiée', 'Dedicated rental', 'Spezialvermietung', 'Noleggio dedicato')}
                        </p>
                        <h3 class="text-2xl font-semibold text-slate-900 dark:text-white">
                          {lamT(
                            'Robot monte-escalier (avec opérateur)',
                            'Stair-climber robot (with operator)',
                            'Treppensteiger-Roboter (mit Bediener)',
                            'Robot montascale (con operatore)'
                          )}
                        </h3>
                        <p class="text-slate-600 dark:text-slate-300">
                          {lamT(
                            'Prestation séparée du déménagement complet. Idéal pour objets lourds en cage d’escalier et accès complexes.',
                            'Separate from full moving service. Ideal for heavy items on stairs and complex access.',
                            'Getrennt vom Komplettumzug. Ideal für schwere Stücke in Treppenhäusern und schwierigen Zugängen.',
                            'Separato dal trasloco completo. Ideale per oggetti pesanti su scale e accessi complessi.'
                          )}
                        </p>
                        <ul class="grid gap-2 text-sm text-slate-700 dark:text-slate-300">
                          <li>
                            •{' '}
                            {lamT(
                              'Location demi-journée ou journée',
                              'Half-day or full-day rental',
                              'Halbtags- oder Tagesmiete',
                              'Noleggio mezza giornata o giornata'
                            )}
                          </li>
                          <li>
                            •{' '}
                            {lamT(
                              'Opérateur formé inclus',
                              'Trained operator included',
                              'Geschulter Bediener inklusive',
                              'Operatore formato incluso'
                            )}
                          </li>
                          <li>
                            •{' '}
                            {lamT(
                              'Tarif selon étages, charge et accès',
                              'Pricing based on floors, load, and access',
                              'Preis nach Etagen, Last und Zugang',
                              'Tariffa in base a piani, carico e accessi'
                            )}
                          </li>
                        </ul>
                        <a
                          class="btn btn-primary w-full justify-center"
                          href={lausanneRobotBookingUrl}
                          target="_blank"
                          rel="noreferrer"
                        >
                          {lausanneRobotCalendlyUrl
                            ? lamT(
                                'Réserver le robot (Calendly)',
                                'Book robot (Calendly)',
                                'Robot buchen (Calendly)',
                                'Prenota robot (Calendly)'
                              )
                            : lamT(
                                'Demander un créneau robot',
                                'Request robot slot',
                                'Robot-Slot anfragen',
                                'Richiedi slot robot'
                              )}
                        </a>
                        {!lausanneRobotCalendlyUrl && (
                          <p class="text-xs text-slate-500 dark:text-slate-400">
                            {lamT(
                              'Ajoutez LAUSANNE_STAIR_ROBOT_CALENDLY_URL pour activer le lien Calendly dédié.',
                              'Set LAUSANNE_STAIR_ROBOT_CALENDLY_URL to enable the dedicated Calendly link.',
                              'Setzen Sie LAUSANNE_STAIR_ROBOT_CALENDLY_URL, um den dedizierten Calendly-Link zu aktivieren.',
                              'Imposta LAUSANNE_STAIR_ROBOT_CALENDLY_URL per attivare il link Calendly dedicato.'
                            )}
                          </p>
                        )}
                      </div>
                      <div class="rounded-2xl border border-slate-200/80 dark:border-slate-800/70 bg-slate-50 dark:bg-slate-900/60 p-3">
                        {lausanneRobotCalendlyUrl ? (
                          <div
                            class="calendly-inline-widget lausanne-calendly-widget"
                            data-url={lausanneRobotCalendlyUrl}
                          />
                        ) : (
                          <div class="rounded-xl border border-slate-200 dark:border-slate-800 bg-white dark:bg-slate-900 p-5 text-sm text-slate-600 dark:text-slate-300">
                            {lamT(
                              'Calendly robot non configuré. Le bouton ouvre le formulaire de contact en attendant.',
                              'Robot Calendly not configured yet. The button currently opens contact form.',
                              'Robot-Calendly noch nicht konfiguriert. Der Button öffnet derzeit das Kontaktformular.',
                              'Calendly robot non ancora configurato. Il pulsante apre il modulo di contatto.'
                            )}
                          </div>
                        )}
                      </div>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          ) : (
            <div class="grid gap-10 lg:gap-12 items-start lg:grid-cols-[1.15fr_0.85fr]">
              <div class="relative">
                <div class="absolute -inset-4 blur-3xl opacity-60 bg-white/60 dark:bg-slate-900/40" />
                <div class="relative rounded-3xl shadow-2xl border border-slate-200/80 dark:border-slate-800/70 bg-white/95 dark:bg-slate-900/90 pricing-card">
                  <Prices
                    title={view.priceTitle}
                    subtitle={view.priceSubtitle}
                    prices={priceList}
                    columns={isEtat ? 2 : 3}
                    classes={{ container: 'max-w-full md:px-8' }}
                  />
                </div>
              </div>
              <div class="rounded-3xl border border-slate-200/70 dark:border-slate-800/70 bg-white/85 dark:bg-slate-900/85 shadow-xl p-8 md:p-10 space-y-4">
                <p class="text-sm uppercase tracking-[0.28em] text-slate-500 dark:text-slate-300">Comment on calcule</p>
                <h3 class="text-2xl md:text-3xl font-semibold text-slate-900 dark:text-white">{view.priceTitle}</h3>
                <p class="text-slate-600 dark:text-slate-300">{view.priceSubtitle}</p>
                <div class="space-y-3">
                  {view.factors.slice(0, 3).map((item) => (
                    <div class="p-4 rounded-2xl border border-slate-200/80 dark:border-slate-800/80 bg-slate-50/80 dark:bg-white/5 shadow-sm">
                      <p class="text-base font-semibold text-slate-900 dark:text-white">{item.title}</p>
                      <p class="text-slate-600 dark:text-slate-300 text-sm mt-1">{item.description}</p>
                    </div>
                  ))}
                </div>
              </div>
            </div>
          )}
        </div>
      </section>

      {isLausanne && lausanneRobotCalendlyUrl && (
        <script is:inline src="https://assets.calendly.com/assets/external/widget.js" async />
      )}

      {isExperience && (
        <Features2
          id="experience-pricing-notes"
          title={lceT(
            'Comment lire nos tarifs',
            'How to read our pricing',
            'Wie man unsere Preise liest',
            'Come leggere i nostri prezzi',
            'كيفية قراءة أسعارنا',
            '如何解读我们的定价'
          )}
          subtitle={lceT(
            'Logique transparente et sans frais cachés',
            'Transparent logic, no hidden fees',
            'Transparente Logik, keine versteckten Gebühren',
            'Logica trasparente, nessun costo nascosto',
            'منطق شفاف بلا رسوم مخفية',
            '透明逻辑，无隐藏费用'
          )}
          columns={3}
          classes={{
            container: 'max-w-6xl',
            items: {
              panel: 'panel-surface rounded-2xl p-5 gap-3 border border-emerald-200/35 bg-white/94 text-slate-900',
            },
          }}
          items={experiencePriceNotes}
        />
      )}

      <Features3
        title={
          isExperience
            ? lceT(
                'Ce qui joue sur le prix',
                'What drives price',
                'Was den Preis beeinflusst',
                'Cosa incide sul prezzo',
                'ما يؤثر على السعر',
                '价格构成因素'
              )
            : 'Ce qui joue sur le prix'
        }
        subtitle={view.priceSubtitle}
        columns={2}
        items={view.factors}
        classes={{ container: 'max-w-5xl' }}
      />

      <Steps
        title={experienceStepsTitle}
        tagline={experienceStepsTagline}
        isReversed={['urgent', 'transport', 'debarras', 'videsuccession', 'videmaison'].includes(brandType)}
        items={view.steps}
      >
        <Fragment slot="image">
          <div
            class="relative aspect-[3/4] overflow-hidden rounded-xl p-10 text-white shadow-xl bg-center bg-cover"
            style={`background-image: linear-gradient(135deg, rgba(0,0,0,0.45), rgba(0,0,0,0.35)), url('${view.stepsBg}');`}
          >
            <p class="text-sm uppercase tracking-[0.35em] text-white/80">{transparencyLabel}</p>
            <p class="mt-6 max-w-xs text-base text-white/90">{transparencyBody}</p>
          </div>
        </Fragment>
      </Steps>

      <FAQs title={experienceFaqTitle} subtitle={view.priceSubtitle} items={view.faqs} />

      <CallToAction actions={view.cta.actions}>
        <Fragment slot="title">{view.cta.title}</Fragment>
        <Fragment slot="subtitle">{view.cta.subtitle}</Fragment>
      </CallToAction>
    </Layout>
  )
}

<style>
  :global(.brand-etatdeslieux .pricing-hero-light h1),
  :global(.brand-etatdeslieux .pricing-hero-light h2),
  :global(.brand-etatdeslieux .pricing-hero-light h3),
  :global(.brand-etatdeslieux .pricing-hero-light h4) {
    color: #0f172a !important;
  }
  :global(.brand-etatdeslieux .pricing-hero-light p),
  :global(.brand-etatdeslieux .pricing-hero-light .text-secondary) {
    color: #1f2937 !important;
  }
</style>

<style>
  :global(.pricing-hero-light h1),
  :global(.pricing-hero-light h2),
  :global(.pricing-hero-light h3),
  :global(.pricing-hero-light h4),
  :global(.pricing-hero-light h5),
  :global(.pricing-hero-light h6),
  :global(.pricing-hero-light .text-muted),
  :global(.pricing-hero-light .text-secondary),
  :global(.pricing-hero-light p),
  :global(.pricing-hero-light .tagline) {
    color: rgba(255, 255, 255, 0.92) !important;
  }
  :global(.pricing-hero-light .text-muted) {
    color: rgba(255, 255, 255, 0.84) !important;
  }
  :global(.pricing-hero-light .hero-chip) {
    color: #0b1220;
    background: rgba(255, 255, 255, 0.9);
    border-color: rgba(255, 255, 255, 0.9);
  }
  :global(.pricing-hero-light .btn-secondary) {
    color: #0b1220;
    background: rgba(255, 255, 255, 0.92);
    border-color: rgba(255, 255, 255, 0.92);
  }
</style>

<style>
  :global(.brand-pedro .move-pricing-hero-overlay) {
    background:
      radial-gradient(138% 90% at 8% 24%, rgba(2, 6, 23, 0.24) 0%, rgba(2, 6, 23, 0.08) 46%, rgba(2, 6, 23, 0) 74%),
      radial-gradient(138% 90% at 92% 24%, rgba(2, 6, 23, 0.2) 0%, rgba(2, 6, 23, 0.08) 44%, rgba(2, 6, 23, 0) 72%),
      linear-gradient(180deg, rgba(2, 6, 23, 0.06) 0%, rgba(2, 6, 23, 0.14) 58%, rgba(2, 6, 23, 0.92) 100%);
  }
  :global(.brand-lausanne .move-pricing-hero-overlay) {
    background:
      radial-gradient(138% 90% at 8% 24%, rgba(2, 6, 23, 0.26) 0%, rgba(2, 6, 23, 0.08) 46%, rgba(2, 6, 23, 0) 74%),
      radial-gradient(138% 90% at 92% 24%, rgba(2, 6, 23, 0.22) 0%, rgba(2, 6, 23, 0.08) 44%, rgba(2, 6, 23, 0) 72%),
      linear-gradient(180deg, rgba(2, 6, 23, 0.06) 0%, rgba(2, 6, 23, 0.14) 58%, rgba(2, 6, 23, 0.92) 100%);
  }
  :global(.brand-urgent .urgent-pricing-hero-overlay) {
    background:
      radial-gradient(
        138% 90% at 8% 24%,
        rgba(127, 29, 29, 0.28) 0%,
        rgba(127, 29, 29, 0.1) 46%,
        rgba(2, 6, 23, 0) 74%
      ),
      radial-gradient(
        138% 90% at 92% 24%,
