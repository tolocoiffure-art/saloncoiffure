---
import '@fontsource-variable/inter';
---

<style is:inline>
  :root {
    --aw-font-sans: 'Inter Variable';
    --aw-font-serif: 'Playfair Display';
    --aw-font-heading: 'Playfair Display';

    --aw-color-primary: rgb(43 29 20);
    --aw-color-secondary: rgb(91 74 61);
    --aw-color-accent: rgb(200 179 138);

    --aw-color-text-heading: rgb(43 29 20);
    --aw-color-text-default: rgb(43 29 20);
    --aw-color-text-muted: rgb(91 74 61 / 80%);
    --aw-color-bg-page: rgb(245 239 232);
    --aw-color-bg-page-dark: rgb(29 20 14);

    ::selection {
      background-color: rgb(200 179 138 / 45%);
    }
  }

  .dark {
    --aw-font-sans: 'Inter Variable';
    --aw-font-serif: 'Playfair Display';
    --aw-font-heading: 'Playfair Display';

    --aw-color-primary: rgb(200 179 138);
    --aw-color-secondary: rgb(241 231 220);
    --aw-color-accent: rgb(200 179 138);

    --aw-color-text-heading: rgb(245 239 232);
    --aw-color-text-default: rgb(245 239 232);
    --aw-color-text-muted: rgb(241 231 220 / 82%);
    --aw-color-bg-page: rgb(29 20 14);

    ::selection {
      background-color: rgb(245 239 232 / 28%);
      color: rgb(245 239 232);
    }
  }
</style>

<style is:global>
  @import url('https://fonts.googleapis.com/css2?family=Playfair+Display:wght@500;600;700&display=swap');
</style>
