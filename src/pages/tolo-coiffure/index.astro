---
import { Image } from 'astro:assets';
import Shell from '~/tenants/tolo-coiffure/Shell.astro';
import { toloContent } from '~/tenants/tolo-coiffure/content';
import { toloServices, bookingCta } from '~/tenants/tolo-coiffure/services';
import { getToloGalleryData } from '~/tenants/tolo-coiffure/gallery';
import { toloCoiffureConfig } from '~/tenants/tolo-coiffure/config';

const metadata = {
  title: 'Tolo Coiffure — Coiffeur à Lausanne Centre',
  description:
    'Atelier de coiffure haut de gamme à Lausanne : balayage signature, coloration précise, coupe éditoriale, soins profonds. Réservez votre rendez-vous.',
  ignoreTitleTemplate: true,
};

const { gallery: toloGallery, heroImage: toloHeroImage, locationImage: toloLocationImage } = await getToloGalleryData();
const secondImageBeforeSwap = toloLocationImage || toloHeroImage;
const thirdImageBeforeSwap = toloGallery[0];
const forcedSecondImage = toloGallery.find((item) => item.filename.toLowerCase() === 'balayage_soft_waves');
const secondImageBeforeSwapSrc = secondImageBeforeSwap?.src;
const secondImageBeforeSwapAlt = secondImageBeforeSwap?.alt || toloContent.location.imageAlt;
const homepageLocationImage = forcedSecondImage?.src || thirdImageBeforeSwap?.src || secondImageBeforeSwapSrc;
const homepageLocationImageAlt = forcedSecondImage?.alt || thirdImageBeforeSwap?.alt || secondImageBeforeSwapAlt;
const homepageGallery =
  thirdImageBeforeSwap && secondImageBeforeSwapSrc
    ? [{ ...thirdImageBeforeSwap, src: secondImageBeforeSwapSrc, alt: secondImageBeforeSwapAlt }, ...toloGallery.slice(1)]
    : toloGallery;
---

<Shell page="home" metadata={metadata}>
  <section class="tc-section tc-hero">
    <div class="tc-hero-text">
      <h1 class="sr-only">{toloContent.hero.srH1}</h1>
      <p class="tc-eyebrow">Coiffeur à Lausanne Centre</p>
      <h2 class="tc-hero-title">{toloContent.hero.title}</h2>
      <p class="tc-subtitle">{toloContent.hero.subtitle}</p>
      <div class="tc-actions">
        <a class="tc-button" href={toloCoiffureConfig.bookingUrl} target="_blank" rel="noreferrer">{toloContent.hero.cta}</a>
        <a class="tc-link" href="/services">Voir nos services</a>
      </div>
    </div>
    <figure class="tc-hero-media">
      {toloHeroImage ? (
        <Image
          src={toloHeroImage.src}
          alt={toloContent.hero.imageAlt}
          loading="eager"
          widths={[720, 1080, 1400]}
          sizes="(max-width: 900px) 100vw, 50vw"
          format="webp"
          quality={84}
        />
      ) : (
        <div aria-hidden="true"></div>
      )}
      <div class="tc-hero-overlay"></div>
    </figure>
  </section>

  <section class="tc-section tc-signature">
    <div class="tc-section-narrow">
      <p class="tc-kicker">Méthode</p>
      <h2>{toloContent.signature.title}</h2>
      <div class="tc-signature-copy">
        {toloContent.signature.paragraphs.map((p) => (
          <p>{p}</p>
        ))}
      </div>
    </div>
  </section>

  <section class="tc-section tc-services" id="services">
    <div class="tc-section-header">
      <p class="tc-kicker">Prestations</p>
      <h2>Services femme & homme</h2>
    </div>
    <div class="tc-service-grid">
      {[toloServices.femme, toloServices.homme].map((category) => (
        <div class="tc-service-column">
          <h3>{category.title}</h3>
          <ul class="tc-service-list">
            {category.items.map((item) => (
              <li>
                <div>
                  <p class="tc-service-title">{item.name}</p>
                  <p class="tc-service-desc">{item.description}</p>
                </div>
                {item.price && <span class="tc-price">{item.price}</span>}
              </li>
            ))}
          </ul>
          <a class="tc-button subtle" href={toloCoiffureConfig.bookingUrl} target="_blank" rel="noreferrer">{bookingCta}</a>
        </div>
      ))}
    </div>
  </section>

  <section class="tc-section tc-location">
    <div class="tc-location-inner">
      <div class="tc-location-overlay"></div>
      <div class="tc-location-content">
        <p class="tc-kicker light">Adresse</p>
        <h2>{toloContent.location.heading}</h2>
        <p class="tc-location-sub">{toloContent.location.subheading}</p>
        <a class="tc-button light" href={toloCoiffureConfig.bookingUrl} target="_blank" rel="noreferrer">{toloCoiffureConfig.bookingLabel}</a>
        <a class="tc-location-map-link" href={toloCoiffureConfig.mapLink} target="_blank" rel="noreferrer">Voir la carte</a>
      </div>
      {homepageLocationImage && (
        <Image
          src={homepageLocationImage}
          alt={homepageLocationImageAlt}
          loading="lazy"
          widths={[900, 1400, 2000]}
          sizes="100vw"
          format="webp"
          quality={80}
        />
      )}
    </div>
  </section>

  <section class="tc-section tc-gallery">
    <div class="tc-section-header">
      <p class="tc-kicker">Galerie</p>
      <h2>Une sélection éditoriale</h2>
    </div>
    <div class="tc-gallery-grid">
      {homepageGallery.map((item) => (
        <figure class={`tc-gallery-item ${item.layout}`}>
          <Image
            src={item.src}
            alt={item.alt}
            loading="lazy"
            widths={[460, 760, 1100]}
            sizes="(max-width: 640px) 100vw, (max-width: 1100px) 50vw, 33vw"
            format="webp"
            quality={80}
          />
        </figure>
      ))}
    </div>
  </section>

  <section class="tc-section tc-testimonials">
    <div class="tc-section-header">
      <p class="tc-kicker">Avis</p>
      <h2>Témoignages</h2>
    </div>
    <div class="tc-testimonial-grid">
      {toloContent.testimonials.map((item) => (
        <a class="tc-testimonial-link" href={item.link} target="_blank" rel="noreferrer" aria-label={`Avis Google de ${item.author}`}>
          <blockquote>
            <div class="tc-review-meta">
              <span class="tc-stars" aria-label={`${item.stars} étoiles`}>{'★'.repeat(item.stars)}</span>
              <span>{item.when}</span>
            </div>
            <p>“{item.quote}”</p>
            <cite>{item.author}</cite>
            <p class="tc-review-author-meta">{item.reviewerMeta}</p>
          </blockquote>
        </a>
      ))}
    </div>
  </section>
</Shell>

<style>
  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }
  .tc-section {
    margin-bottom: var(--tc-gap);
  }
  .tc-hero {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 2.5rem;
    align-items: center;
  }
  .tc-hero-text {
    display: grid;
    gap: 1rem;
    padding: clamp(1.25rem, 2.4vw, 2rem);
    border-radius: 18px;
    background: color-mix(in srgb, var(--tc-surface) 82%, var(--tc-accent) 18%);
    border: 1px solid color-mix(in srgb, var(--tc-accent) 34%, transparent);
  }
  .tc-eyebrow {
    letter-spacing: 0.12em;
    text-transform: uppercase;
    font-size: 0.82rem;
    color: var(--tc-muted);
  }
  .tc-hero-title {
    font-family: var(--tc-font-heading);
    font-size: clamp(2.4rem, 4vw, 3.3rem);
    letter-spacing: -0.02em;
    line-height: 1.05;
  }
  .tc-subtitle {
    font-size: 1.1rem;
    color: var(--tc-muted);
  }
  .tc-actions {
    display: flex;
    gap: 1rem;
    align-items: center;
    flex-wrap: wrap;
  }
  .tc-button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    padding: 0.65rem 1.2rem;
    border-radius: 999px;
    border: 1.4px solid var(--tc-accent);
    color: var(--tc-text);
    text-decoration: none;
    background: color-mix(in srgb, var(--tc-accent) 12%, transparent);
    transition: background 160ms ease, border-color 160ms ease, transform 120ms ease;
  }
  .tc-button:hover {
    background: color-mix(in srgb, var(--tc-accent) 20%, var(--tc-bg) 80%);
    border-color: color-mix(in srgb, var(--tc-accent) 80%, var(--tc-text) 20%);
    transform: translateY(-1px);
  }
  .tc-button.subtle {
    background: transparent;
  }
  .tc-button.light {
    color: #f5efe8;
    border-color: color-mix(in srgb, #f5efe8 65%, #c8b38a 35%);
    background: color-mix(in srgb, #f5efe8 12%, transparent);
  }
  .tc-button.light:hover {
    background: color-mix(in srgb, #f5efe8 18%, #1d140e 82%);
  }
  .tc-link {
    text-decoration: none;
    color: var(--tc-muted);
    font-weight: 600;
    letter-spacing: 0.01em;
  }
  .tc-hero-media {
    position: relative;
    overflow: hidden;
    border-radius: 18px;
    background: #1d140e;
    min-height: 360px;
  }
  .tc-hero-media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    filter: saturate(0.95) brightness(0.92);
  }
  .tc-hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(120deg, rgba(0, 0, 0, 0.38), rgba(0, 0, 0, 0.16), rgba(0, 0, 0, 0.05));
    pointer-events: none;
  }

  .tc-section-narrow {
    max-width: 700px;
    margin: 0 auto;
    display: grid;
    gap: 1.1rem;
  }
  .tc-kicker {
    letter-spacing: 0.14em;
    text-transform: uppercase;
    font-size: 0.78rem;
    color: var(--tc-muted);
  }
  .tc-kicker.light {
    color: color-mix(in srgb, #f5efe8 85%, #ffffff 15%);
  }
  h2 {
    font-family: var(--tc-font-heading);
    font-size: clamp(1.7rem, 3vw, 2.35rem);
    letter-spacing: -0.01em;
    margin: 0;
  }
  .tc-signature-copy {
    display: grid;
    gap: 0.85rem;
    color: var(--tc-muted);
    font-size: 1.03rem;
    line-height: 1.55;
  }

  .tc-section-header {
    margin-bottom: 1.5rem;
  }

  .tc-services {
    display: grid;
    gap: 1.5rem;
  }
  .tc-service-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
    gap: 1.5rem;
  }
  .tc-service-column {
    padding: 1.2rem 1.3rem;
    border-radius: 16px;
    background: var(--tc-surface);
    border: 1px solid var(--tc-line);
    display: grid;
    gap: 1rem;
  }
  .tc-service-column h3 {
    font-family: var(--tc-font-heading);
    letter-spacing: 0.01em;
    margin: 0;
  }
  .tc-service-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: 1rem;
  }
  .tc-service-list li {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 0.5rem 1rem;
    align-items: start;
  }
  .tc-service-title {
    font-weight: 600;
    letter-spacing: -0.005em;
  }
  .tc-service-desc {
    margin-top: 0.2rem;
    color: var(--tc-muted);
    line-height: 1.5;
  }
  .tc-price {
    color: var(--tc-text);
    font-weight: 600;
    letter-spacing: 0.01em;
  }

  .tc-location {
    margin-bottom: calc(var(--tc-gap) + 10px);
  }
  .tc-location-inner {
    position: relative;
    width: min(calc(100vw - 2rem), 1360px);
    margin-left: 50%;
    transform: translateX(-50%);
    border-radius: 18px;
    overflow: hidden;
    min-height: clamp(280px, 30vw, 340px);
  }
  .tc-location-inner img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    filter: saturate(0.92) brightness(0.82);
  }
  .tc-location-overlay {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.15);
  }
  .tc-location-content {
    position: absolute;
    inset: 0;
    padding: clamp(1.5rem, 4vw, 2.8rem);
    display: grid;
    gap: 0.7rem;
    align-content: center;
    max-width: 540px;
    color: #f5efe8;
  }
  .tc-location-sub {
    font-size: 1.05rem;
    color: color-mix(in srgb, #f5efe8 82%, #ffffff 18%);
  }
  .tc-location-map-link {
    color: #f5efe8;
    text-decoration: none;
    font-size: 0.9rem;
    letter-spacing: 0.03em;
    opacity: 0.92;
  }

  .tc-gallery-grid {
    display: grid;
    grid-template-columns: repeat(6, 1fr);
    gap: 0.75rem;
  }
  .tc-gallery-item {
    position: relative;
    overflow: hidden;
    border-radius: 14px;
    background: #1d140e;
  }
  .tc-gallery-item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    filter: saturate(0.96) brightness(0.92);
  }
  .tc-gallery-item.large { grid-column: span 4; grid-row: span 2; min-height: 320px; }
  .tc-gallery-item.wide { grid-column: span 3; grid-row: span 1; min-height: 200px; }
  .tc-gallery-item.tall { grid-column: span 2; grid-row: span 2; min-height: 320px; }
  .tc-gallery-item.square { grid-column: span 2; grid-row: span 1; min-height: 200px; }

  .tc-testimonial-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 1rem;
  }
  .tc-testimonial-link {
    text-decoration: none;
    color: inherit;
    display: block;
    height: 100%;
  }
  .tc-testimonial-grid blockquote {
    margin: 0;
    padding: 1.2rem 1.25rem;
    border: 1px solid var(--tc-line);
    border-radius: 14px;
    background: color-mix(in srgb, var(--tc-surface) 90%, #ffffff 10%);
    display: grid;
    gap: 0.75rem;
    height: 100%;
    transition: border-color 160ms ease, background 160ms ease;
  }
  .tc-testimonial-link:hover blockquote {
    border-color: color-mix(in srgb, var(--tc-accent) 55%, var(--tc-line));
    background: color-mix(in srgb, var(--tc-surface) 80%, #ffffff 20%);
  }
  .tc-review-meta {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.65rem;
    font-size: 0.84rem;
    color: var(--tc-muted);
  }
  .tc-stars {
    color: #b58d45;
    letter-spacing: 0.1em;
    font-size: 0.82rem;
    white-space: nowrap;
  }
  .tc-testimonial-grid p {
    font-size: 1.02rem;
    line-height: 1.5;
  }
  .tc-testimonial-grid cite {
    font-style: normal;
    color: var(--tc-muted);
    letter-spacing: 0.02em;
  }
  .tc-review-author-meta {
    margin: 0;
    font-size: 0.84rem;
    color: var(--tc-muted);
  }

  @media (max-width: 1100px) {
    .tc-gallery-item.large { grid-column: span 6; }
    .tc-gallery-item.tall { grid-column: span 3; }
    .tc-gallery-item.wide { grid-column: span 4; }
    .tc-gallery-item.square { grid-column: span 3; }
  }
  @media (max-width: 820px) {
    .tc-gallery-grid { grid-template-columns: repeat(4, 1fr); }
    .tc-gallery-item.large { grid-column: span 4; }
    .tc-gallery-item.wide { grid-column: span 4; }
    .tc-gallery-item.tall { grid-column: span 2; }
    .tc-gallery-item.square { grid-column: span 2; }
    .tc-location-inner {
      width: calc(100vw - 1.5rem);
      min-height: clamp(240px, 62vw, 300px);
    }
  }
  @media (max-width: 640px) {
    .tc-gallery-grid { grid-template-columns: repeat(2, 1fr); }
    .tc-gallery-item.large,
    .tc-gallery-item.wide,
    .tc-gallery-item.tall,
    .tc-gallery-item.square { grid-column: span 2; }
    .tc-service-list li { grid-template-columns: 1fr; }
    .tc-service-list li .tc-price { justify-self: start; }
  }
</style>
