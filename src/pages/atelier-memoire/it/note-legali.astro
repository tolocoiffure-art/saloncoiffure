---
import Shell from '~/tenants/atelier-memoire/ui/Shell.astro';
import LegalPage from '~/tenants/atelier-memoire/pages/LegalPage.astro';
import { getAtelierCopy } from '~/tenants/atelier-memoire/copy';

const locale = 'it';
const copy = getAtelierCopy(locale);
const metadata = { title: `${copy.meta.title} — Note legali`, description: copy.meta.description, ignoreTitleTemplate: true };
---

<Shell locale={locale} page="legal" metadata={metadata}>
  <LegalPage locale={locale} />
</Shell>
