---
import Shell from '~/tenants/atelier-memoire/ui/Shell.astro';

const SUPPORTED_LOCALES = ['fr', 'en', 'de', 'it'] as const;

function resolveLocale() {
  const query = Astro.url.searchParams.get('lang');
  if (query && SUPPORTED_LOCALES.includes(query.toLowerCase() as any)) return query.toLowerCase() as typeof SUPPORTED_LOCALES[number];
  const header = Astro.request.headers.get('accept-language') || '';
  const [raw] = header.split(',');
  if (raw) {
    const base = raw.split(';')[0]?.split('-')[0]?.toLowerCase();
    if (base && SUPPORTED_LOCALES.includes(base as any)) return base as typeof SUPPORTED_LOCALES[number];
  }
  return 'fr';
}

const locale = resolveLocale();
const sessionId = Astro.url.searchParams.get('session_id') || '';
const method = Astro.url.searchParams.get('method') || '';
const intake = Astro.url.searchParams.get('intake') || '';
const count = Number(Astro.url.searchParams.get('count') || 0);
const totalMinor = Number(Astro.url.searchParams.get('total') || 0);
const hasSession = Boolean(sessionId);

const TEXT = {
  fr: {
    metadataTitle: 'Merci — Atelier Mémoire',
    headingWithSession: 'Merci pour votre commande',
    headingGeneric: 'Merci',
    descAwaiting: 'Nous confirmons votre paiement…',
    descGeneric: 'Nous revenons vers vous sous un jour ouvré.',
    descConfirmed: 'Votre paiement est confirmé. Vous recevrez un e-mail avec les prochaines étapes.',
    offlineInvoice: 'Nous vous envoyons une facture QR sous 24h.',
    offlineTwint: 'Nous vous envoyons un QR TWINT sous 24h.',
    offlineFallback: 'Nous vous recontactons rapidement pour finaliser le paiement.',
    intakeMail: 'Envoyez l’original à : Avenue de la Gare 29, 1003 Lausanne (courrier suivi conseillé).',
    intakeOnline: 'Vous pouvez envoyer vos fichiers via WeTransfer/Drive si ce n’est pas déjà fait.',
    emailLabel: 'Email',
    orderLabel: 'Commande n°',
    amountLabel: 'Montant',
    statusLabel: 'Statut',
    photosLabel: 'Photos',
    methodLabel: 'Paiement',
    intakeLabel: 'Envoi',
    loading: 'Chargement des détails du paiement…',
    error: 'Impossible de charger les détails. Merci de contacter le support.',
    home: "Revenir à l’accueil",
    currencyLocale: 'fr-CH',
  },
  en: {
    metadataTitle: 'Thank you — Atelier Mémoire',
    headingWithSession: 'Thank you for your order',
    headingGeneric: 'Thank you',
    descAwaiting: 'We are confirming your payment…',
    descGeneric: 'We will get back to you within one business day.',
    descConfirmed: 'Your payment is confirmed. You will receive an email with the next steps.',
    offlineInvoice: 'We will send a QR-bill within 24h.',
    offlineTwint: 'We will send a TWINT QR within 24h.',
    offlineFallback: 'We will contact you shortly to finalize payment.',
    intakeMail: 'Send the original to: Avenue de la Gare 29, 1003 Lausanne (tracked mail recommended).',
    intakeOnline: 'You can send your files via WeTransfer/Drive if not already done.',
    emailLabel: 'Email',
    orderLabel: 'Order #',
    amountLabel: 'Amount',
    statusLabel: 'Status',
    photosLabel: 'Photos',
    methodLabel: 'Payment',
    intakeLabel: 'Delivery',
    loading: 'Loading payment details…',
    error: 'Unable to load details. Please contact support.',
    home: 'Back to homepage',
    currencyLocale: 'en-CH',
  },
  de: {
    metadataTitle: 'Danke — Atelier Mémoire',
    headingWithSession: 'Danke für Ihre Bestellung',
    headingGeneric: 'Danke',
    descAwaiting: 'Wir bestätigen Ihre Zahlung…',
    descGeneric: 'Wir melden uns innerhalb eines Werktages.',
    descConfirmed: 'Ihre Zahlung ist bestätigt. Sie erhalten eine E-Mail mit den nächsten Schritten.',
    offlineInvoice: 'Wir senden Ihnen eine QR-Rechnung innerhalb von 24h.',
    offlineTwint: 'Wir senden Ihnen einen TWINT-QR innerhalb von 24h.',
    offlineFallback: 'Wir melden uns zur finalen Zahlungsabwicklung.',
    intakeMail: 'Original senden an: Avenue de la Gare 29, 1003 Lausanne (Einschreiben empfohlen).',
    intakeOnline: 'Sie können Ihre Dateien per WeTransfer/Drive senden.',
    emailLabel: 'E-Mail',
    orderLabel: 'Bestellung Nr.',
    amountLabel: 'Betrag',
    statusLabel: 'Status',
    photosLabel: 'Fotos',
    methodLabel: 'Zahlung',
    intakeLabel: 'Versand',
    loading: 'Zahlungsdetails werden geladen…',
    error: 'Details konnten nicht geladen werden. Bitte kontaktieren Sie den Support.',
    home: 'Zur Startseite',
    currencyLocale: 'de-CH',
  },
  it: {
    metadataTitle: 'Grazie — Atelier Mémoire',
    headingWithSession: 'Grazie per il tuo ordine',
    headingGeneric: 'Grazie',
    descAwaiting: 'Stiamo confermando il pagamento…',
    descGeneric: 'Ti ricontatteremo entro un giorno lavorativo.',
    descConfirmed: 'Il pagamento è confermato. Riceverai un’email con i prossimi passi.',
    offlineInvoice: 'Invieremo una fattura QR entro 24h.',
    offlineTwint: 'Invieremo un QR TWINT entro 24h.',
    offlineFallback: 'Ti contatteremo per finalizzare il pagamento.',
    intakeMail: 'Invia l’originale a: Avenue de la Gare 29, 1003 Lausanne (raccomandata consigliata).',
    intakeOnline: 'Puoi inviare i file via WeTransfer/Drive.',
    emailLabel: 'Email',
    orderLabel: 'Ordine n°',
    amountLabel: 'Importo',
    statusLabel: 'Stato',
    photosLabel: 'Foto',
    methodLabel: 'Pagamento',
    intakeLabel: 'Invio',
    loading: 'Caricamento dei dettagli del pagamento…',
    error: 'Impossibile caricare i dettagli. Contatta il supporto.',
    home: 'Torna alla home',
    currencyLocale: 'it-CH',
  },
} as const;

const copy = TEXT[locale];
const metadata = { title: copy.metadataTitle, ignoreTitleTemplate: true };
const formatCurrency = (valueMinor: number) => {
  if (!Number.isFinite(valueMinor) || valueMinor <= 0) return '—';
  return new Intl.NumberFormat(copy.currencyLocale, { style: 'currency', currency: 'CHF' }).format(valueMinor / 100);
};
---

<Shell locale={locale} page="contact" metadata={metadata}>
  <section class="grid gap-6">
    <div>
      <h1 class="text-3xl font-semibold" style={`font-family:var(--atelier-font-heading);`}>{hasSession ? copy.headingWithSession : copy.headingGeneric}</h1>
      <p class="text-sm text-[color:var(--atelier-muted)]" id="desc">{hasSession ? copy.descAwaiting : copy.descGeneric}</p>
    </div>

    {!hasSession ? (
      <div class="grid gap-3 rounded-2xl border border-[color:var(--atelier-line)] p-5" style="background:var(--atelier-surface);">
        <p class="text-sm">
          {method === 'invoice'
            ? copy.offlineInvoice
            : method === 'twint'
            ? copy.offlineTwint
            : copy.offlineFallback}
        </p>
        <div class="grid gap-1 text-sm">
          <p><strong>{copy.photosLabel}:</strong> {count || '—'}</p>
          <p><strong>{copy.amountLabel}:</strong> {formatCurrency(totalMinor)}</p>
          <p><strong>{copy.intakeLabel}:</strong> {intake || '—'}</p>
        </div>
        <div class="text-xs text-[color:var(--atelier-muted)]">
          {intake === 'mail' ? copy.intakeMail : copy.intakeOnline}
        </div>
      </div>
    ) : null}

    {hasSession ? (
      <div id="session" class="rounded-2xl border border-[color:var(--atelier-line)] p-5 text-sm" style="background:var(--atelier-surface);">
        <div id="loader">{copy.loading}</div>
        <div id="content" class="hidden">
          <p><strong>{copy.emailLabel}:</strong> <span id="email">—</span></p>
          <p><strong>{copy.orderLabel}</strong> <span id="orderNumber">—</span></p>
          <p><strong>{copy.amountLabel}:</strong> <span id="amount">—</span></p>
          <p><strong>{copy.photosLabel}:</strong> <span id="photos">—</span></p>
          <p><strong>{copy.methodLabel}:</strong> <span id="method">—</span></p>
          <p><strong>{copy.intakeLabel}:</strong> <span id="intake">—</span></p>
          <p><strong>{copy.statusLabel}:</strong> <span id="status">—</span></p>
        </div>
        <div id="error" class="hidden text-red-400">{copy.error}</div>
      </div>
    ) : null}

    <a href="/atelier-memoire" class="px-4 py-2 rounded-full border border-[color:var(--atelier-line)] w-fit text-sm">
      {copy.home}
    </a>
  </section>

  {hasSession ? (
    <script is:inline define:vars={{ copy }}>
      const params = new URLSearchParams(location.search);
      const id = params.get('session_id');
      if (id) {
        fetch(`/api/payment/session?session_id=${encodeURIComponent(id)}`)
          .then(r => (r.ok ? r.json() : Promise.reject(new Error('HTTP ' + r.status))))
          .then(data => {
            const amountMinor = typeof data.amount_total_order === 'number' ? data.amount_total_order : data.amount_total;
            const currency = (data.currency || 'CHF').toUpperCase();
            const formatter = new Intl.NumberFormat(copy.currencyLocale, { style: 'currency', currency });
            document.getElementById('email').textContent = data.customer_email || data.metadata?.email || '—';
            document.getElementById('orderNumber').textContent = data.order_number || '—';
            document.getElementById('amount').textContent = typeof amountMinor === 'number' ? formatter.format((amountMinor || 0) / 100) : '—';
            document.getElementById('photos').textContent = data.metadata?.photo_count || '—';
            document.getElementById('method').textContent = data.metadata?.payment || 'card';
            document.getElementById('intake').textContent = data.metadata?.intake || '—';
            document.getElementById('status').textContent = data.payment_status || '—';
            document.getElementById('loader').classList.add('hidden');
            document.getElementById('content').classList.remove('hidden');
            document.getElementById('desc').textContent = copy.descConfirmed;
          })
          .catch(() => {
            document.getElementById('loader').classList.add('hidden');
            document.getElementById('error').classList.remove('hidden');
          });
      }
    </script>
  ) : null}
</Shell>
