---
import Shell from '~/tenants/atelier-memoire/ui/Shell.astro';
import HomePage from '~/tenants/atelier-memoire/pages/HomePage.astro';
import { getAtelierCopy } from '~/tenants/atelier-memoire/copy';

const locale = 'de';
const copy = getAtelierCopy(locale);
const metadata = { title: copy.meta.title, description: copy.meta.description, ignoreTitleTemplate: true };
---

<Shell locale={locale} page="home" metadata={metadata}>
  <HomePage locale={locale} />
</Shell>
