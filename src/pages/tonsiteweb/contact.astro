---
import Layout from '~/layouts/PageLayout.astro';
import HeroText from '~/components/widgets/HeroText.astro';
import ContactUs from '~/components/widgets/Contact.astro';
import Features2 from '~/components/widgets/Features2.astro';

const metadata = {
  title: 'Contact',
};
---

<Layout metadata={metadata}>
  <!-- HeroText Widget ******************* -->

  <HeroText
    tagline="Contact"
    title="Formulaire niveau FAANG"
    subtitle="Un parcours guidé qui capte vos besoins (sites 1.5–5k CHF) et détecte les projets sur‑mesure 10–70k+ sans vous faire sentir la complexité."
  />

  <ContactUs
    id="form"
    title="Brief express, sans jargon"
    subtitle="4 mini-étapes, 2 minutes. Donnez-nous les grandes lignes, nous cadrons et décidons pour vous."
    inputs={[
      { type: 'section', label: 'Étape 1 — Votre activité' },
      { type: 'text', name: 'name', label: 'Nom et prénom', required: true, requiredMessage: 'Merci d’indiquer votre nom.' },
      {
        type: 'email',
        name: 'email',
        label: 'Email professionnel',
        required: true,
        requiredMessage: 'Nous avons besoin de votre email pour répondre.',
      },
      {
        type: 'tel',
        name: 'phone',
        label: 'Téléphone (WhatsApp ok)',
        helper: 'Optionnel, mais utile pour valider rapidement.',
      },
      { type: 'text', name: 'company', label: 'Entreprise / marque', required: true },
      { type: 'text', name: 'website', label: 'Site actuel (optionnel)', placeholder: 'https://votresite.ch' },
      {
        type: 'select',
        name: 'industry',
        label: 'Secteur',
        required: true,
        options: [
          { label: 'Déménagement / services locaux', value: 'local-services' },
          { label: 'Restauration / hospitality', value: 'hospitality' },
          { label: 'Retail / e-commerce', value: 'retail' },
          { label: 'Services professionnels (avocat, fiduciaire, gérance)', value: 'professional' },
          { label: 'Immobilier', value: 'real-estate' },
          { label: 'Événementiel / expérience', value: 'experience' },
          { label: 'Autre', value: 'other' },
        ],
      },
      {
        type: 'checkbox',
        name: 'languages',
        label: 'Langues du site',
        helper: 'Choisissez 1 à 3 langues ou laissez vide si vous hésitez.',
        options: [
          { label: 'Français', value: 'fr' },
          { label: 'Anglais', value: 'en' },
          { label: 'Allemand', value: 'de' },
          { label: 'Italien', value: 'it' },
        ],
      },

      { type: 'section', label: 'Étape 2 — Ce que vous voulez obtenir' },
      {
        type: 'checkbox',
        name: 'goals',
        label: 'Ce que le site doit faire',
        helper: 'Sélectionnez ce qui compte le plus, nous arbitrons le reste.',
        options: [
          { label: 'Être contacté facilement', value: 'contact' },
          { label: 'Prendre des réservations / rendez-vous', value: 'booking' },
          { label: 'Présenter mes services / portfolio', value: 'portfolio' },
          { label: 'Être visible sur Google (SEO)', value: 'seo' },
          { label: 'Je ne sais pas encore, guidez-moi', value: 'unknown-goal' },
          { label: 'Autre', value: 'other-goal' },
        ],
      },
      {
        type: 'text',
        name: 'goal_detail',
        label: 'Précisez votre objectif',
        placeholder: 'Ex. tunnel de réservation + paiement acompte',
        conditional: { source: 'goals[]', showOn: ['other-goal'] },
      },

      { type: 'section', label: 'Étape 3 — Cadre rapide' },
      {
        type: 'radio',
        name: 'budget',
        label: 'Ordre de grandeur du projet',
        helper: 'Choisissez ce qui vous ressemble le plus, nous ajustons ensuite.',
        required: true,
        requiredMessage: 'Choisissez un ordre de grandeur.',
        options: [
          { label: 'Site simple (≈1–1.5k)', value: 'entry' },
          { label: 'Site évolutif (≈3–5k)', value: 'advanced' },
          { label: 'Projet structurant (10k+)', value: 'custom' },
          { label: 'Je ne sais pas encore', value: 'unknown' },
        ],
      },
      {
        type: 'text',
        name: 'delivery_track_entry',
        label: 'Voie projet',
        attributes: { value: 'Essentiel (≈1–1.5k) — livraison rapide sans atelier', readOnly: true, disabled: true },
        className: 'bg-slate-50 dark:bg-slate-800/70 rounded-xl px-3 py-2',
        conditional: { source: 'budget', showOn: ['entry'] },
      },
      {
        type: 'text',
        name: 'delivery_track_avance',
        label: 'Voie projet',
        attributes: { value: 'Avancé (≈3–5k) — template + logique métier légère', readOnly: true, disabled: true },
        className: 'bg-slate-50 dark:bg-slate-800/70 rounded-xl px-3 py-2',
        conditional: { source: 'budget', showOn: ['advanced'] },
      },
      {
        type: 'text',
        name: 'delivery_track_custom',
        label: 'Voie projet',
        attributes: { value: 'Sur-mesure (10k+) — cadrage + gouvernance', readOnly: true, disabled: true },
        className: 'bg-amber-50 dark:bg-slate-800/70 rounded-xl px-3 py-2 text-amber-900',
        conditional: { source: 'budget', showOn: ['custom'] },
      },
      {
        type: 'radio',
        name: 'timeline',
        label: 'Délai souhaité',
        options: [
          { label: 'ASAP (≤10 jours ouvrés)', value: 'asap' },
          { label: '2–4 semaines', value: '2-4w' },
          { label: '1–2 mois', value: '1-2m' },
          { label: 'Flexible', value: 'flexible' },
        ],
      },
      {
        type: 'text',
        name: 'template_preference',
        label: 'Template préféré (optionnel)',
        placeholder: 'Ex. LCE, Maestro, Classic',
      },
      {
        type: 'checkbox',
        name: 'commitment',
        label: 'Validation',
        required: true,
        requiredMessage: 'Merci de confirmer.',
        options: [{ label: 'Ce formulaire sert à cadrer un projet réel et prioritaire.', value: 'confirmed' }],
      },

      { type: 'section', label: 'Étape 4 — Contact et suite' },
      {
        type: 'radio',
        name: 'contact_channel',
        label: 'Contact privilégié',
        options: [
          { label: 'Email', value: 'email' },
          { label: 'WhatsApp', value: 'whatsapp' },
          { label: 'Téléphone', value: 'phone' },
        ],
      },
      {
        type: 'radio',
        name: 'next_step',
        label: 'Vous préférez',
        options: [
          { label: 'Démarrer directement (1.5–5k)', value: 'start-now' },
          { label: 'Un call de 10 minutes (projets 10–70k)', value: 'call-10' },
        ],
      },
    ]}
    textarea={{
      label: 'Notes ou exigences spécifiques (optionnel)',
      placeholder: 'Ajoutez un détail clé : contraintes légales, CRM à connecter, volumes précis… (400 caractères max).',
      rows: 4,
    }}
    disclaimer={{
      label:
        'En envoyant ce formulaire, vous acceptez que TonSiteWeb.ch traite vos données pour répondre à votre demande, conformément à notre politique de confidentialité.',
    }}
    description="Nos bureaux sont ouverts du lundi au vendredi, 9h-17h. Nous parlons français, anglais et allemand."
  />

  <!-- Features2 Widget ************** -->

  <Features2
    title="Contact direct"
    subtitle="Choisissez le canal qui vous convient le mieux."
    items={[
      {
        title: 'Téléphone',
        description: '+41 76 798 27 93',
        icon: 'tabler:phone',
      },
      {
        title: 'Email',
        description: 'support@tonsiteweb.ch',
        icon: 'tabler:mail',
      },
      {
        title: 'Adresse',
        description: 'Avenue de la Gare 29, 1003 Lausanne',
        icon: 'tabler:map-pin',
      },
      {
        title: 'Disponibilité',
        description: 'Du lundi au vendredi, 9h00 – 17h00',
        icon: 'tabler:calendar-time',
      },
      {
        title: 'Support client',
        description: 'support@tonsiteweb.ch — réponse sous un jour ouvré',
        icon: 'tabler:help',
      },
    ]}
  />
</Layout>
