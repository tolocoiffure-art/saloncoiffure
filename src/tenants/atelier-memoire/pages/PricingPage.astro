---
import type { AtelierLocale } from '../copy';
import { getAtelierCopy } from '../copy';

interface Props {
  locale: AtelierLocale;
}

const { locale } = Astro.props as Props;
const copy = getAtelierCopy(locale);
---

<section class="grid gap-6">
  <div>
    <h1 class="text-3xl font-semibold" style={`font-family:var(--atelier-font-heading);`}>{copy.pricingTeaser.title}</h1>
    <p class="text-sm text-[color:var(--atelier-muted)]">{copy.pricingTeaser.footnote}</p>
  </div>
  <div class="grid gap-4 md:grid-cols-3">
    {copy.pricingTeaser.items.map((item) => (
      <div class="p-5 rounded-2xl shadow-sm border border-[color:var(--atelier-line)] flex flex-col gap-3" style="background:var(--atelier-surface);">
        <div>
          <p class="text-sm uppercase tracking-[0.18em] text-[color:var(--atelier-muted)]">{item.title}</p>
          <p class="text-lg font-semibold" style={`font-family:var(--atelier-font-heading);`}>{item.price}</p>
        </div>
        <ul class="grid gap-2 text-sm">
          {item.bullets.map((b) => (
            <li>• {b}</li>
          ))}
        </ul>
      </div>
    ))}
  </div>
  <div class="p-4 rounded-xl border border-[color:var(--atelier-line)] text-sm leading-relaxed" style="background:var(--atelier-surface);">
    {copy.pipeline.paymentItems.join(' · ')}
  </div>

  <div class="p-5 rounded-2xl border border-[color:var(--atelier-line)] shadow-sm grid gap-3" style="background:var(--atelier-surface);">
    <p class="text-sm uppercase tracking-[0.16em] text-[color:var(--atelier-muted)]">Estimation</p>
    <div class="flex flex-col sm:flex-row gap-3 items-start sm:items-center">
      <label class="text-sm flex items-center gap-2">
        <span>Nombre de photos</span>
        <input
          id="price-count"
          type="number"
          min="1"
          max="100"
          value="1"
          class="w-20 rounded-lg border border-[color:var(--atelier-line)] px-2 py-1 text-sm"
          style="background:var(--atelier-surface); color:var(--atelier-text);"
        />
      </label>
      <div class="text-sm text-[color:var(--atelier-muted)]">Remise progressive : -10% sur chaque photo supplémentaire (min CHF 10).</div>
    </div>
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-3 text-sm">
      <div class="rounded-xl border border-[color:var(--atelier-line)] p-3" style="background:var(--atelier-surface);">
        <p class="text-xs uppercase tracking-[0.12em] text-[color:var(--atelier-muted)]">Total estimé</p>
        <p id="price-total" class="text-lg font-semibold" style={`font-family:var(--atelier-font-heading);`}>CHF 49.00</p>
      </div>
      <div class="rounded-xl border border-[color:var(--atelier-line)] p-3" style="background:var(--atelier-surface);">
        <p class="text-xs uppercase tracking-[0.12em] text-[color:var(--atelier-muted)]">Prix dernière photo</p>
        <p id="price-last" class="text-lg font-semibold" style={`font-family:var(--atelier-font-heading);`}>CHF 49.00</p>
      </div>
      <div class="rounded-xl border border-[color:var(--atelier-line)] p-3" style="background:var(--atelier-surface);">
        <p class="text-xs uppercase tracking-[0.12em] text-[color:var(--atelier-muted)]">Moyenne par photo</p>
        <p id="price-avg" class="text-lg font-semibold" style={`font-family:var(--atelier-font-heading);`}>CHF 49.00</p>
      </div>
    </div>
  </div>
</section>

<script is:inline>
  if (typeof window !== 'undefined') {
    const basePrice = 49;
    const discountFactor = 0.9;
    const minPrice = 10;
    const countInput = document.getElementById('price-count');
    const totalEl = document.getElementById('price-total');
    const lastEl = document.getElementById('price-last');
    const avgEl = document.getElementById('price-avg');

    const format = (value) => `CHF ${value.toFixed(2)}`;

    const compute = (count) => {
      const n = Math.min(Math.max(Math.floor(count), 1), 100);
      let total = 0;
      let price = basePrice;
      for (let i = 0; i < n; i++) {
        if (i > 0) price = Math.max(minPrice, price * discountFactor);
        total += price;
      }
      const last = price;
      const avg = total / n;
      return { total, last, avg, n };
    };

    const render = () => {
      if (!(countInput instanceof HTMLInputElement) || !totalEl || !lastEl || !avgEl) return;
      const { total, last, avg, n } = compute(Number(countInput.value || '1'));
      countInput.value = String(n);
      totalEl.textContent = format(total);
      lastEl.textContent = format(last);
      avgEl.textContent = format(avg);
    };

    countInput?.addEventListener('input', render);
    countInput?.addEventListener('change', render);
    render();
  }
</script>
