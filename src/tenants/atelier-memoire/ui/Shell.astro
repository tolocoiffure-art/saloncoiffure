---
import Layout from '~/layouts/Layout.astro';
import type { MetaData } from '~/types';
import type { AtelierLocale } from '../copy';
import { atelierMemoireTheme } from '../theme';

type PageKey = 'home' | 'pricing' | 'contact' | 'legal';

interface Props {
  locale: AtelierLocale;
  page: PageKey;
  metadata?: MetaData;
}

const { locale, page, metadata = {} } = Astro.props as Props;

const base = '/atelier-memoire';
const localePath = locale === 'fr' ? '' : `/${locale}`;
const basePath = `${base}${localePath}`;

const navLabels: Record<AtelierLocale, { home: string; pricing: string; contact: string; legal: string }> = {
  fr: { home: 'Accueil', pricing: 'Prix', contact: 'Contact', legal: 'Mentions légales' },
  en: { home: 'Home', pricing: 'Pricing', contact: 'Contact', legal: 'Legal' },
  de: { home: 'Start', pricing: 'Preise', contact: 'Kontakt', legal: 'Rechtliches' },
  it: { home: 'Home', pricing: 'Prezzi', contact: 'Contatto', legal: 'Note legali' },
};

const slugs = {
  home: '',
  pricing: { fr: 'prix', en: 'pricing', de: 'preise', it: 'prezzi' },
  contact: { fr: 'contact', en: 'contact', de: 'kontakt', it: 'contatto' },
  legal: { fr: 'mentions-legales', en: 'legal', de: 'rechtliches', it: 'note-legali' },
} as const;

const nav = [
  { href: `${basePath}`, key: 'home', label: navLabels[locale].home },
  { href: `${basePath}/${slugs.pricing[locale]}`.replace('//', '/'), key: 'pricing', label: navLabels[locale].pricing },
  { href: `${basePath}/${slugs.contact[locale]}`.replace('//', '/'), key: 'contact', label: navLabels[locale].contact },
  { href: `${basePath}/${slugs.legal[locale]}`.replace('//', '/'), key: 'legal', label: navLabels[locale].legal },
];

const languages: AtelierLocale[] = ['fr', 'en', 'de', 'it'];
const langLabels = { fr: 'FR', en: 'EN', de: 'DE', it: 'IT' } as const;
const styleVars = {
  '--atelier-bg': atelierMemoireTheme.colors.background,
  '--atelier-surface': atelierMemoireTheme.colors.surface,
  '--atelier-text': atelierMemoireTheme.colors.text,
  '--atelier-muted': atelierMemoireTheme.colors.muted,
  '--atelier-accent': atelierMemoireTheme.colors.accent,
  '--atelier-line': atelierMemoireTheme.colors.line,
  '--atelier-max': atelierMemoireTheme.layout.maxWidth,
  '--atelier-font-heading': atelierMemoireTheme.fonts.heading,
  '--atelier-font-body': atelierMemoireTheme.fonts.body,
};
---

<Layout metadata={metadata} brandKey="ateliermemoire" styleVars={styleVars}>
  <div class="min-h-screen" style="background:var(--atelier-bg); color:var(--atelier-text); font-family:var(--atelier-font-body);">
    <header class="mx-auto w-full max-w-5xl px-5 py-6 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3">
      <a class="flex items-baseline gap-3" href={basePath}>
        <span class="text-xs tracking-[0.4em] uppercase text-[color:var(--atelier-muted)]">ATELIER</span>
        <span class="text-lg font-semibold tracking-[0.3em]" style={`font-family:${atelierMemoireTheme.fonts.heading};`}>MÉMOIRE</span>
      </a>
      <nav class="flex items-center gap-3 flex-wrap text-sm">
        {nav.map((item) => (
          <a
            href={item.href}
            class={`px-3 py-2 rounded-full border transition ${
              item.key === page
                ? 'border-[color:var(--atelier-accent)] text-[color:var(--atelier-accent)]'
                : 'border-transparent text-[color:var(--atelier-text)] hover:border-[color:var(--atelier-line)]'
            }`}
            style={item.key === page ? 'background:var(--atelier-surface);' : 'background:transparent;'}
          >
            {item.label}
          </a>
        ))}
        <div class="flex items-center gap-2">
          {languages.map((lang) => {
            const href = lang === 'fr' ? `${base}` : `${base}/${lang}`;
            return (
              <a
                href={href}
                class={`px-2 py-1 text-xs rounded-full border ${
                  lang === locale
                    ? 'border-[color:var(--atelier-accent)] text-[color:var(--atelier-accent)]'
                    : 'border-transparent text-[color:var(--atelier-muted)] hover:border-[color:var(--atelier-line)]'
                }`}
                style={lang === locale ? 'background:var(--atelier-surface);' : 'background:transparent;'}
              >
                {langLabels[lang]}
              </a>
            );
          })}
        </div>
      </nav>
    </header>

    <main class="mx-auto w-full max-w-5xl px-5 pb-16">
      <slot />
    </main>

    <footer class="border-t mt-10 pt-6 pb-10 border-[color:var(--atelier-line)] text-sm text-[color:var(--atelier-muted)]">
      <div class="mx-auto w-full max-w-5xl px-5 grid gap-2">
        <p>
          <a href={basePath} class="text-[color:var(--atelier-text)]">Atelier Mémoire</a>, Lausanne —
          <a href="mailto:bonjour@ateliermemoire.ch" class="text-[color:var(--atelier-text)]">bonjour@ateliermemoire.ch</a>
        </p>
        <p>Paiement carte ou facture. Originaux renvoyés en suivi si envoyés par courrier.</p>
      </div>
    </footer>
  </div>
</Layout>

<style>
  @import url('https://fonts.googleapis.com/css2?family=Libre+Baskerville:wght@400;700&family=Inter:wght@400;500;600&display=swap');
</style>
