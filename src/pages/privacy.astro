---
import PrivacyContent from './privacy.content.md';
import { resolveTenantFromRequest } from '~/lib/tenants';
import { resolveTonSiteWebComponent } from '~/tenants/tonsiteweb/router';

const tenant = resolveTenantFromRequest(Astro.request);

const TonComponent =
  tenant.slug === 'tonsiteweb'
    ? resolveTonSiteWebComponent('privacy', Astro.url instanceof URL ? Astro.url : new URL(Astro.request.url), Astro.request)
    : null;
---

{TonComponent ? <TonComponent /> : <PrivacyContent />}
