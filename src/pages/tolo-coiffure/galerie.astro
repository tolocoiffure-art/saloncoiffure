---
import { Image } from 'astro:assets';
import Shell from '~/tenants/tolo-coiffure/Shell.astro';
import { getToloGalleryData } from '~/tenants/tolo-coiffure/gallery';

const metadata = {
  title: 'Galerie — Tolo Coiffure',
  description: 'Sélection éditoriale des réalisations Tolo Coiffure : balayage, coupes précises, détails d’atelier.',
  ignoreTitleTemplate: true,
};

const { fullGallery: toloGallery } = await getToloGalleryData();
---

<Shell page="galerie" metadata={metadata}>
  <section class="tc-section">
    <p class="tc-kicker">Galerie</p>
    <h1 class="tc-title">Éditorial, sans surcharge</h1>
    <p class="tc-lead">
      Images équilibrées, lumière douce, reflets contrôlés. Pas de filtres saturés, uniquement des textures soignées.
    </p>
  </section>

  <section class="tc-section">
    <div class="tc-gallery-grid">
      {
        toloGallery.map((item) => (
          <figure class={`tc-gallery-item ${item.layout}`}>
            <Image
              src={item.src}
              alt={item.alt}
              loading="lazy"
              widths={[560, 900, 1300]}
              sizes="(max-width: 640px) 100vw, (max-width: 1100px) 50vw, 33vw"
              format="webp"
              quality={80}
            />
            <figcaption>{item.alt}</figcaption>
          </figure>
        ))
      }
    </div>
  </section>
</Shell>

<style>
  .tc-section {
    margin-bottom: 110px;
  }
  .tc-kicker {
    letter-spacing: 0.14em;
    text-transform: uppercase;
    font-size: 0.8rem;
    color: var(--tc-muted);
  }
  .tc-title {
    font-family: var(--tc-font-heading);
    font-size: clamp(2rem, 3.6vw, 2.5rem);
    letter-spacing: -0.012em;
    margin: 0.25rem 0 0.7rem;
  }
  .tc-lead {
    max-width: 760px;
    color: var(--tc-muted);
    font-size: 1.05rem;
    line-height: 1.6;
  }
  .tc-gallery-grid {
    display: grid;
    grid-template-columns: repeat(6, 1fr);
    gap: 0.75rem;
  }
  .tc-gallery-item {
    position: relative;
    overflow: hidden;
    border-radius: 14px;
    background: #1d140e;
  }
  .tc-gallery-item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    filter: saturate(0.96) brightness(0.92);
  }
  .tc-gallery-item figcaption {
    position: absolute;
    left: 0.75rem;
    bottom: 0.7rem;
    color: #f5efe8;
    font-size: 0.9rem;
    letter-spacing: 0.01em;
    text-shadow: 0 6px 18px rgba(0, 0, 0, 0.45);
  }
  .tc-gallery-item.large {
    grid-column: span 4;
    grid-row: span 2;
    min-height: 320px;
  }
  .tc-gallery-item.wide {
    grid-column: span 3;
    grid-row: span 1;
    min-height: 220px;
  }
  .tc-gallery-item.tall {
    grid-column: span 2;
    grid-row: span 2;
    min-height: 320px;
  }
  .tc-gallery-item.square {
    grid-column: span 2;
    grid-row: span 1;
    min-height: 220px;
  }

  @media (max-width: 1100px) {
    .tc-gallery-item.large {
      grid-column: span 6;
    }
    .tc-gallery-item.wide {
      grid-column: span 4;
    }
    .tc-gallery-item.tall {
      grid-column: span 3;
    }
    .tc-gallery-item.square {
      grid-column: span 3;
    }
  }
  @media (max-width: 820px) {
    .tc-gallery-grid {
      grid-template-columns: repeat(4, 1fr);
    }
    .tc-gallery-item.large {
      grid-column: span 4;
    }
    .tc-gallery-item.wide {
      grid-column: span 4;
    }
    .tc-gallery-item.tall {
      grid-column: span 2;
    }
    .tc-gallery-item.square {
      grid-column: span 2;
    }
  }
  @media (max-width: 640px) {
    .tc-section {
      margin-bottom: 90px;
    }
    .tc-gallery-grid {
      grid-template-columns: repeat(2, 1fr);
    }
    .tc-gallery-item.large,
    .tc-gallery-item.wide,
    .tc-gallery-item.tall,
    .tc-gallery-item.square {
      grid-column: span 2;
    }
  }
</style>
