---
import { Image } from 'astro:assets';

import Shell from '~/tenants/maison-cortes/ui/Shell.astro';
import { maisonCortesCopy, resolveMaisonCortesLocale } from '~/tenants/maison-cortes/copy';
import {
  SELECTION_COOKIE_NAME,
  getMaisonCortesInventorySnapshot,
  parseSelectionCookie,
  releaseReservation,
} from '~/tenants/maison-cortes/inventory';
import { getMaisonCortesImage } from '~/tenants/maison-cortes/images';
import { maisonCortesProducts } from '~/tenants/maison-cortes/products';

export const prerender = false;

const locale = resolveMaisonCortesLocale(Astro.cookies.get('mc-lang')?.value);
const copy = maisonCortesCopy.locales[locale];
const rawSelections = parseSelectionCookie(Astro.cookies.get(SELECTION_COOKIE_NAME)?.value);
const snapshot = await getMaisonCortesInventorySnapshot();
const productMap = new Map(maisonCortesProducts.map((p) => [p.id, p]));

const validSelections = [];
for (const entry of rawSelections) {
  const product = productMap.get(entry.sku);
  if (!product) {
    if (entry.reservationId) await releaseReservation(entry.sku, entry.reservationId);
    continue;
  }
  const state = snapshot[entry.sku];
  const hasReservation = entry.reservationId && state?.reservationIds?.includes(entry.reservationId);
  const status = state?.status ?? product.status ?? 'available';
  const isAvailable = status === 'available' && (!entry.reservationId || hasReservation);
  if (!isAvailable) {
    if (entry.reservationId) await releaseReservation(entry.sku, entry.reservationId);
    continue;
  }
  validSelections.push(entry);
}

if (validSelections.length !== rawSelections.length) {
  const cookieValue = validSelections.length ? encodeURIComponent(validSelections.map((e) => `${e.sku}|${e.reservationId ?? ''}`).join(',')) : '';
  Astro.response.headers.set(
    'Set-Cookie',
    `${SELECTION_COOKIE_NAME}=${cookieValue}; Path=/; Max-Age=${validSelections.length ? 60 * 60 * 24 : 0}; SameSite=Lax`
  );
}

const metadata = {
  title: `MAISON CORTES — ${copy.selectionTitle}`,
  description: validSelections.length ? copy.selectionLead : copy.selectionEmpty,
  ignoreTitleTemplate: true,
};
---

<Shell metadata={metadata} title={copy.selectionTitle}>
  <section class="mc-section">
    {validSelections.length ? (
      validSelections.map((entry) => {
        const product = productMap.get(entry.sku)!;
        const state = snapshot[entry.sku];
        const reservation = entry.reservationId ? state?.reservations?.find((res) => res.id === entry.reservationId) : null;
        const minutesLeft =
          reservation && reservation.expiresAt ? Math.max(1, Math.ceil((reservation.expiresAt - Date.now()) / 60000)) : null;
        const status = state?.status ?? product.status ?? 'available';
        const productImage = getMaisonCortesImage(product.id);

        return (
          <article class="mc-selection-card">
            <p class="mc-classification">
              <a class="mc-city" href={`/maison-cortes/${product.citySlug}`}>{product.city}</a>
              <span aria-hidden="true"> / </span>
              <a class="mc-object" href={`/maison-cortes/${product.citySlug}/${product.objectSlug}`}>
                {product.object} {product.index}
              </a>
            </p>
            {productImage && (
              <figure class="mc-figure" data-full={productImage.src.src} data-alt={productImage.alt}>
                <Image
                  src={productImage.src}
                  alt={productImage.alt}
                  widths={[420, 600, 820]}
                  sizes="(min-width: 960px) 520px, 100vw"
                  format="webp"
                  class="mc-image"
                  loading="lazy"
                />
                <button type="button" class="mc-zoom-btn" aria-label="Agrandir l’image">⤢</button>
              </figure>
            )}
            <div class="mc-meta">
              <span class="mc-label">{copy.statusLabels[status]}</span>
              {product.editionSize && <span class="mc-footnote">{copy.editionLabel} {product.editionSize}</span>}
            </div>
            <ul class="mc-specs">
              {product.specs.map((spec) => (
                <li>{spec}</li>
              ))}
            </ul>
            <p class="mc-price">CHF {product.priceChf}.–</p>
            <div class="mc-actions">
              <form method="post" action="/api/maison-cortes/checkout">
                <input type="hidden" name="sku" value={product.id} />
                {entry.reservationId && <input type="hidden" name="reservationId" value={entry.reservationId} />}
                <button type="submit" class="mc-button">{copy.selectionPrimary}</button>
              </form>
              <form method="post" action="/api/maison-cortes/select">
                <input type="hidden" name="clear" value="1" />
                <input type="hidden" name="sku" value={product.id} />
                <input type="hidden" name="redirect" value="/maison-cortes/selection" />
                <button type="submit" class="mc-button mc-button-ghost">{copy.selectionRemove}</button>
              </form>
            </div>
            {minutesLeft && <p class="mc-footnote">{copy.selectionHold.replace('{minutes}', String(minutesLeft))}</p>}
          </article>
        );
      })
    ) : (
      <>
        <p>{copy.selectionEmpty}</p>
        <a class="mc-button" href="/maison-cortes">{copy.selectionBack}</a>
      </>
    )}
  </section>
</Shell>

<style>
  .mc-selection-card {
    display: grid;
    gap: 12px;
    padding: 12px 0;
    border-top: 1px solid var(--mc-border);
  }

  .mc-selection-card:first-of-type {
    border-top: none;
    padding-top: 0;
  }

  .mc-button-ghost {
    border-color: var(--mc-border);
  }

  .mc-figure {
    margin: 0 auto;
    width: min(420px, 100%);
    aspect-ratio: 4 / 5;
    background: #f8fafc;
    border: 1px solid var(--mc-border);
    border-radius: 10px;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    position: relative;
    cursor: zoom-in;
  }

  .mc-image {
    width: 100%;
    height: 100%;
    display: block;
    object-fit: contain;
    transition: transform 180ms ease-out;
  }

  .mc-figure:hover .mc-image {
    transform: scale(1.04);
  }

  .mc-zoom-btn {
    position: absolute;
    bottom: 10px;
    right: 10px;
    border: 1px solid var(--mc-border);
    background: rgba(255, 255, 255, 0.9);
    border-radius: 999px;
    padding: 6px 10px;
    font-size: 12px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    cursor: pointer;
  }

  .mc-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    align-items: center;
  }
</style>
