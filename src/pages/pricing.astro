---
import Layout from '~/layouts/PageLayout.astro';
import Prices from '~/components/widgets/Pricing.astro';
import FAQs from '~/components/widgets/FAQs.astro';
import Steps from '~/components/widgets/Steps.astro';
import Features2 from '~/components/widgets/Features2.astro';
import Features3 from '~/components/widgets/Features3.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';
import { getBrandFromHost } from '~/lib/brand';
import { BRANDS } from '~/lib/brands.config';
import { getImage } from '~/data/imageInventory';
import type { ImageId } from '~/data/imageInventory';
import { resolveLocaleFromRequest } from '~/lib/locale';
import { resolveTenantFromRequest } from '~/lib/tenants';
import { resolveTonSiteWebComponent } from '~/tenants/tonsiteweb/router';

const tenant = resolveTenantFromRequest(Astro.request);

const TonComponent =
  tenant.slug === 'tonsiteweb'
    ? resolveTonSiteWebComponent(
        'pricing',
        Astro.url instanceof URL ? Astro.url : new URL(Astro.request.url),
        Astro.request
      )
    : null;

const hostCandidates = [
  Astro.request.headers.get('x-forwarded-host'),
  Astro.request.headers.get('host'),
  new URL(Astro.request.url).host,
]
  .flatMap((value) => (value || '').split(','))
  .map((value) => value.toLowerCase().trim().split(':')[0])
  .filter(Boolean);
const isToloHost = hostCandidates.some((host) => host.includes('tolocoiffure.ch'));
if (tenant.slug === 'tolo-coiffure' || isToloHost) {
  return Astro.rewrite('/tolo-coiffure/services');
}

if (tenant.slug === 'ateliermemoire' && !(Astro.url?.pathname || '').startsWith('/atelier-memoire')) {
  const target = new URL('/atelier-memoire/prix', Astro.url instanceof URL ? Astro.url : new URL(Astro.request.url));
  return Astro.redirect(target.toString(), 308);
}

const host = Astro.request.headers.get('host');
const brandKey = getBrandFromHost(host);
if (!TonComponent && brandKey === 'maisoncortes') {
  return Astro.redirect('/maison-cortes');
}

const isUrgent = brandKey === 'urgent';
const isUrgentPricing = isUrgent;
const brandType = isUrgent
  ? 'urgent'
  : brandKey === 'transport'
    ? 'transport'
    : brandKey === 'debarras'
      ? 'debarras'
      : brandKey === 'videmaison'
        ? 'videmaison'
        : brandKey === 'videsuccession'
          ? 'videsuccession'
          : brandKey === 'nettoyagesuccession' || brandKey === 'lausannenettoyage'
            ? 'clean'
            : brandKey === 'etatdeslieux'
              ? 'etatdeslieux'
              : brandKey === 'laclemanexperience'
                ? 'experience'
                : 'move';
const brand = BRANDS[brandKey] || BRANDS.pedro;
const whatsapp = brand?.whatsapp || 'https://wa.me/41767982793';
const img = (id: ImageId) => getImage(id);
const heroToneClass = brandKey === 'tonsiteweb' ? 'pricing-hero-dark' : 'pricing-hero-light';
const isEtat = brandKey === 'etatdeslieux';
const isExperience = brandKey === 'laclemanexperience';
const isLausanne = brandKey === 'lausanne';
const defaultLocale = isExperience ? 'en' : 'fr';
const locale = resolveLocaleFromRequest(Astro.request, defaultLocale);
const lang = isExperience
  ? ['fr', 'en', 'de', 'it', 'ar', 'zh'].includes(locale)
    ? locale
    : defaultLocale
  : isLausanne
    ? ['fr', 'en', 'de', 'it'].includes(locale)
      ? locale
      : 'fr'
    : 'fr';
const isEn = lang === 'en';
const isDe = lang === 'de';
const isIt = lang === 'it';
const isAr = lang === 'ar';
const isZh = lang === 'zh';
const lceT = <T,>(fr: T, en: T, de: T, it: T, ar?: T, zh?: T): T => {
  if (!isExperience) return fr;
  if (isEn) return en;
  if (isDe) return de;
  if (isIt) return it;
  if (isAr && ar !== undefined) return ar;
  if (isZh && zh !== undefined) return zh;
  return fr;
};
const lamT = <T,>(fr: T, en: T, de: T, it: T): T => {
  if (!isLausanne) return fr;
  if (isEn) return en;
  if (isDe) return de;
  if (isIt) return it;
  return fr;
};
const experienceStepsTitle = isExperience
  ? lceT(
      'Comment nous calculons',
      'How we calculate',
      'Wie wir kalkulieren',
      'Come calcoliamo',
      'كيف نحسب',
      '我们如何计算'
    )
  : 'Comment nous calculons';
const experienceStepsTagline = isExperience
  ? lceT('Processus', 'Process', 'Prozess', 'Processo', 'العملية', '流程')
  : 'Processus';
const transparencyLabel = isExperience
  ? lceT('Transparence', 'Transparency', 'Transparenz', 'Trasparenza', 'شفافية', '透明度')
  : 'Transparence';
const transparencyBody = isExperience
  ? lceT(
      'Prix en CHF, TVA incluse, sans frais cachés. Ajustements seulement si volume ou options changent.',
      'Prices in CHF, VAT included, no hidden fees. Adjustments only if scope or options change.',
      'Preise in CHF inkl. MwSt., keine versteckten Gebühren. Anpassungen nur bei geändertem Umfang/Optionen.',
      'Prezzi in CHF IVA inclusa, nessun costo nascosto. Adeguamenti solo se cambiano perimetro/opzioni.',
      'أسعار بالفرنك مع ضريبة، بلا رسوم خفية. تعديلات فقط إذا تغيّر الحجم أو الخيارات.',
      '价格为瑞郎含税，无隐藏费用。仅在范围或选项变化时调整。'
    )
  : 'Prix en CHF, TVA incluse, sans frais cachés. Ajustements seulement si volume ou options changent.';
