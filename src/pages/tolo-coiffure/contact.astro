---
import Shell from '~/tenants/tolo-coiffure/Shell.astro';
import { toloCoiffureConfig } from '~/tenants/tolo-coiffure/config';

const metadata = {
  title: 'Contact — Tolo Coiffure Lausanne',
  description:
    'Prendre rendez-vous chez Tolo Coiffure : téléphone, email, adresse Rue Pré-du-Marché 6, 1004 Lausanne. Horaires et plan d’accès.',
  ignoreTitleTemplate: true,
};
---

<Shell page="contact" metadata={metadata}>
  <section class="tc-section">
    <p class="tc-kicker">Contact</p>
    <h1 class="tc-title">Réserver un rendez-vous</h1>
    <p class="tc-lead">Choisissez votre créneau en ligne via Calendly, ou contactez-nous directement sur WhatsApp pour une réponse rapide.</p>
  </section>

  <section class="tc-section tc-contact-grid">
    <div class="tc-card">
      <p class="tc-kicker small">Coordonnées</p>
      <h2>Tolo Coiffure</h2>
      <ul class="tc-list">
        <li><span>Adresse</span><span>{toloCoiffureConfig.address}</span></li>
        <li><span>Téléphone</span><a href={toloCoiffureConfig.telHref} target="_blank" rel="noreferrer">{toloCoiffureConfig.phone}</a></li>
        <li><span>Email</span><a href={`mailto:${toloCoiffureConfig.email}`}>{toloCoiffureConfig.email}</a></li>
      </ul>
      <div class="tc-button-row">
        <a class="tc-button" href={toloCoiffureConfig.bookingUrl} target="_blank" rel="noreferrer">
          {toloCoiffureConfig.bookingLabel}
        </a>
        <a class="tc-button secondary" href={toloCoiffureConfig.whatsappUrl} target="_blank" rel="noreferrer">
          Écrire sur WhatsApp
        </a>
      </div>
      <p class="tc-meta-note">Calendly pour réserver en ligne, WhatsApp pour une prise de contact immédiate.</p>
    </div>

    <div class="tc-card">
      <p class="tc-kicker small">Horaires</p>
      <ul class="tc-hours">
        <li><span>Lu</span><span>10:00 – 18:00</span></li>
        <li><span>Ma – Je</span><span>09:00 – 19:00</span></li>
        <li><span>Ve – Sa</span><span>08:00 – 18:00</span></li>
        <li><span>Dim</span><span>Fermé</span></li>
      </ul>
      <a class="tc-link" href={toloCoiffureConfig.mapLink} target="_blank" rel="noreferrer">Ouvrir la carte</a>
    </div>
  </section>

  {toloCoiffureConfig.calendlyUrl && (
    <section class="tc-section">
      <div class="tc-calendly-card">
        <p class="tc-kicker small">Réservation en ligne</p>
        <h2>Calendly</h2>
        <div class="calendly-inline-widget tc-calendly-widget" data-url={toloCoiffureConfig.calendlyUrl}></div>
      </div>
    </section>
  )}

  <section class="tc-section">
    <div class="tc-map">
      <iframe
        title="Plan Tolo Coiffure"
        src={toloCoiffureConfig.mapEmbed}
        loading="lazy"
        referrerpolicy="no-referrer-when-downgrade"
      />
    </div>
  </section>
  {toloCoiffureConfig.calendlyUrl && (
    <script is:inline src="https://assets.calendly.com/assets/external/widget.js" async></script>
  )}
</Shell>

<style>
  .tc-section { margin-bottom: 110px; }
  .tc-kicker {
    letter-spacing: 0.14em;
    text-transform: uppercase;
    font-size: 0.8rem;
    color: var(--tc-muted);
  }
  .tc-kicker.small { font-size: 0.72rem; letter-spacing: 0.12em; }
  .tc-title {
    font-family: var(--tc-font-heading);
    font-size: clamp(2rem, 3.8vw, 2.5rem);
    letter-spacing: -0.012em;
    margin: 0.25rem 0 0.7rem;
  }
  .tc-lead {
    max-width: 760px;
    color: var(--tc-muted);
    font-size: 1.05rem;
    line-height: 1.6;
  }
  .tc-contact-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 1.2rem;
  }
  .tc-card {
    background: var(--tc-surface);
    border: 1px solid var(--tc-line);
    border-radius: 16px;
    padding: 1.25rem 1.3rem;
    display: grid;
    gap: 0.85rem;
  }
  .tc-card h2 {
    font-family: var(--tc-font-heading);
    font-size: 1.45rem;
    margin: 0;
    letter-spacing: -0.01em;
  }
  .tc-list {
    list-style: none;
    padding: 0;
    margin: 0.2rem 0 0;
    display: grid;
    gap: 0.6rem;
    font-size: 1rem;
  }
  .tc-list li {
    display: grid;
    grid-template-columns: 120px 1fr;
    gap: 0.5rem;
    color: var(--tc-muted);
  }
  .tc-list a { color: var(--tc-text); text-decoration: none; font-weight: 600; }
  .tc-hours {
    list-style: none;
    padding: 0;
    margin: 0.4rem 0 0.6rem;
    display: grid;
    gap: 0.4rem;
    color: var(--tc-muted);
  }
  .tc-hours li {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
  }
  .tc-button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    padding: 0.65rem 1.15rem;
    border-radius: 999px;
    border: 1.4px solid var(--tc-accent);
    color: var(--tc-text);
    text-decoration: none;
    background: color-mix(in srgb, var(--tc-accent) 10%, transparent);
    transition: background 160ms ease, border-color 160ms ease;
    width: fit-content;
  }
  .tc-button:hover {
    background: color-mix(in srgb, var(--tc-accent) 18%, var(--tc-bg) 82%);
    border-color: color-mix(in srgb, var(--tc-accent) 80%, var(--tc-text) 20%);
  }
  .tc-button-row {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.65rem;
  }
  .tc-button.secondary {
    background: transparent;
  }
  .tc-link {
    color: var(--tc-text);
    font-weight: 600;
    text-decoration: none;
  }
  .tc-calendly-card {
    background: var(--tc-surface);
    border: 1px solid var(--tc-line);
    border-radius: 16px;
    padding: 1.25rem 1.3rem;
    display: grid;
    gap: 0.85rem;
  }
  .tc-calendly-card h2 {
    font-family: var(--tc-font-heading);
    font-size: 1.45rem;
    margin: 0;
    letter-spacing: -0.01em;
  }
  .tc-calendly-widget {
    min-width: 320px;
    height: 700px;
  }
  .tc-map {
    border-radius: 18px;
    overflow: hidden;
    border: 1px solid var(--tc-line);
    box-shadow: 0 18px 40px -28px rgba(0, 0, 0, 0.35);
    background: #1d140e;
  }
  .tc-map iframe {
    width: 100%;
    height: 320px;
    border: 0;
    display: block;
  }
  .tc-meta-note {
    margin: 0;
    font-size: 0.86rem;
    color: var(--tc-muted);
    line-height: 1.45;
  }
  @media (max-width: 640px) {
    .tc-section { margin-bottom: 90px; }
    .tc-list li { grid-template-columns: 1fr; }
    .tc-calendly-widget {
      min-width: 100%;
      height: 680px;
    }
    .tc-map iframe { height: 260px; }
  }
</style>
