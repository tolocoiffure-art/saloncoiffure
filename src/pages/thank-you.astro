---
import Layout from '~/layouts/PageLayout.astro';
import { resolveTenantFromRequest } from '~/lib/tenants';
import { resolveTonSiteWebComponent } from '~/tenants/tonsiteweb/router';

const tenant = resolveTenantFromRequest(Astro.request);

const TonComponent =
  tenant.slug === 'tonsiteweb'
    ? resolveTonSiteWebComponent('thank-you', Astro.url instanceof URL ? Astro.url : new URL(Astro.request.url), Astro.request)
    : null;

const metadata = { title: 'Merci — Pedro Déménagement' };
---

{TonComponent ? (
  <TonComponent />
) : (
<Layout metadata={metadata}>
  <section class="py-24">
    <div class="container mx-auto max-w-2xl text-center">
      <h1 class="text-3xl font-bold">Merci pour votre demande</h1>
      <p class="mt-4 text-muted">
        Nous revenons vers vous sous 24h pour confirmer le volume, la date souhaitée et les options dont vous avez besoin.
      </p>
      <div class="mt-8 space-y-2 text-sm text-muted">
        <p>Si votre demande est urgente, appelez le +41 76 798 27 93.</p>
        <p>Vous pouvez aussi compléter des détails supplémentaires en répondant à notre email.</p>
      </div>
      <div class="mt-10 flex gap-3 justify-center">
        <a href="/" class="btn btn-primary">Retour à l’accueil</a>
        <a href="/services" class="btn btn-secondary">Voir nos services</a>
      </div>
    </div>
  </section>
</Layout>
)}
