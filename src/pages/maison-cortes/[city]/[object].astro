---
import { Image } from 'astro:assets';

import Shell from '~/tenants/maison-cortes/ui/Shell.astro';
import { getMaisonCortesImage } from '~/tenants/maison-cortes/images';
import { getMaisonCortesInventorySnapshot } from '~/tenants/maison-cortes/inventory';
import { maisonCortesProducts } from '~/tenants/maison-cortes/products';
import { maisonCortesCopy, resolveMaisonCortesLocale } from '~/tenants/maison-cortes/copy';

export const prerender = false;

export function getStaticPaths() {
  return maisonCortesProducts.map((product) => ({
    params: { city: product.citySlug, object: product.objectSlug },
  }));
}

const { city, object } = Astro.params;
const product = maisonCortesProducts.find((item) => item.citySlug === city && item.objectSlug === object);
if (!product) {
  throw new Error('Object not found');
}

const locale = resolveMaisonCortesLocale(Astro.cookies.get('mc-lang')?.value);
const copy = maisonCortesCopy.locales[locale];
const snapshot = await getMaisonCortesInventorySnapshot();
const state = snapshot[product.id];
const computedStatus = state?.status ?? product.status;
const statusLabel = copy.statusLabels[computedStatus];
const isAvailable = computedStatus === 'available';
const productImage = getMaisonCortesImage(product.id);

const metadata = {
  title: `MAISON CORTES — ${product.city} ${product.object} ${product.index}`,
  description: `${product.city} ${product.object} ${product.index}.`,
  ignoreTitleTemplate: true,
};
---

<Shell metadata={metadata}>
  <section class="mc-section">
    <div class="mc-brand">
      <span class="mc-brand-top">{maisonCortesCopy.brandTop}</span>
      <span class="mc-brand-bottom">{maisonCortesCopy.brandBottom}</span>
    </div>
    <p class="mc-classification">
      <a class="mc-city" href={`/maison-cortes/${product.citySlug}`}>{product.city}</a>
      <span aria-hidden="true"> / </span>
      <a class="mc-object" href={`/maison-cortes/${product.citySlug}/${product.objectSlug}`}>
        {product.object} {product.index}
      </a>
    </p>
    {productImage && (
      <figure class="mc-figure" data-full={productImage.src.src} data-alt={productImage.alt}>
        <Image
          src={productImage.src}
          alt={productImage.alt}
          widths={[520, 720, 960]}
          sizes="(min-width: 960px) 720px, 100vw"
          format="webp"
          class="mc-image"
          loading="lazy"
        />
        <button type="button" class="mc-zoom-btn" aria-label="Agrandir l’image">⤢</button>
      </figure>
    )}
    <div class="mc-meta">
      <span class="mc-label">{statusLabel}</span>
      {product.editionSize && <span class="mc-footnote">{copy.editionLabel} {product.editionSize}</span>}
    </div>
    <ul class="mc-specs">
      {product.specs.map((spec) => (
        <li>{spec}</li>
      ))}
    </ul>
    <p class="mc-price">CHF {product.priceChf}.–</p>
    {isAvailable ? (
      <form method="post" action="/api/maison-cortes/select">
        <input type="hidden" name="sku" value={product.id} />
        <input type="hidden" name="redirect" value="/maison-cortes/selection" />
        <button type="submit" class="mc-button">{copy.selectionAction}</button>
      </form>
    ) : (
      <p class="mc-footnote">{copy.statusUnavailable}</p>
    )}
  </section>
  <section class="mc-section">
    <h2>{copy.materialsTitle}</h2>
    <ul class="mc-quiet-list">
      <li>{copy.materialsBody}</li>
      <li>{copy.labDisclosureShort}</li>
      <li>{copy.careLine}</li>
      <li>{copy.shippingLine}</li>
      <li>{copy.returnsBody}</li>
    </ul>
  </section>
</Shell>

<style>
  .mc-lightbox {
    position: fixed;
    inset: 0;
    display: none;
    align-items: center;
    justify-content: center;
    z-index: 60;
  }

  .mc-lightbox.is-open {
    display: flex;
  }

  .mc-lightbox-backdrop {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.65);
    backdrop-filter: blur(2px);
  }

  .mc-lightbox-content {
    position: relative;
    max-width: min(90vw, 820px);
    max-height: 90vh;
    background: #ffffff;
    border-radius: 14px;
    padding: 16px;
    box-shadow: 0 22px 80px rgba(15, 23, 42, 0.2);
    display: grid;
    gap: 12px;
    z-index: 1;
  }

  .mc-lightbox-img {
    max-width: 100%;
    max-height: 75vh;
    object-fit: contain;
    display: block;
    border-radius: 8px;
    background: #f8fafc;
  }

  .mc-lightbox-close {
    position: absolute;
    top: 10px;
    right: 10px;
    border: 1px solid #cbd5e1;
    border-radius: 999px;
    width: 34px;
    height: 34px;
    font-size: 18px;
    background: #ffffff;
    cursor: pointer;
  }

  .mc-lightbox-counter {
    font-size: 12px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--mc-muted);
    text-align: center;
  }

  .mc-brand {
    display: grid;
    gap: 4px;
    text-transform: uppercase;
  }

  .mc-brand-top {
    font-size: 14px;
    letter-spacing: var(--mc-tracking-city);
  }

  .mc-brand-bottom {
    font-size: 28px;
    letter-spacing: var(--mc-tracking-brand);
  }

  .mc-price {
    margin: 0;
    font-size: 18px;
    letter-spacing: 0.1em;
  }

  .mc-figure {
    margin: 0 auto;
    width: min(420px, 100%);
    aspect-ratio: 4 / 5;
    background: #f8fafc;
    border: 1px solid var(--mc-border);
    border-radius: 10px;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    position: relative;
    cursor: zoom-in;
  }

  .mc-image {
    width: 100%;
    height: 100%;
    display: block;
    object-fit: contain;
    transition: transform 180ms ease-out;
  }

  .mc-figure:hover .mc-image {
    transform: scale(1.04);
  }

  .mc-zoom-btn {
    position: absolute;
    bottom: 10px;
    right: 10px;
    border: 1px solid var(--mc-border);
    background: rgba(255, 255, 255, 0.9);
    border-radius: 999px;
    padding: 6px 10px;
    font-size: 12px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    cursor: pointer;
  }

  form {
    margin: 0;
  }
</style>
