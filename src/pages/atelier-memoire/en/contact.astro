---
import Shell from '~/tenants/atelier-memoire/ui/Shell.astro';
import ContactPage from '~/tenants/atelier-memoire/pages/ContactPage.astro';
import { getAtelierCopy } from '~/tenants/atelier-memoire/copy';

const locale = 'en';
const copy = getAtelierCopy(locale);
const metadata = { title: `${copy.meta.title} — Contact`, description: copy.meta.description, ignoreTitleTemplate: true };
---

<Shell locale={locale} page="contact" metadata={metadata}>
  <ContactPage locale={locale} />
</Shell>
