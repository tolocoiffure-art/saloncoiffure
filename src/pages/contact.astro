---
import Layout from '~/layouts/PageLayout.astro';
import ContactUs from '~/components/widgets/Contact.astro';
import Features2 from '~/components/widgets/Features2.astro';
import { getBrandFromHost } from '~/lib/brand';
import { BRANDS } from '~/lib/brands.config';
import { getImage, getImageAlt } from '~/data/imageInventory';
import type { ImageId } from '~/data/imageInventory';
import { resolveLocaleFromRequest } from '~/lib/locale';
import { resolveTenantFromRequest } from '~/lib/tenants';
import { resolveTonSiteWebComponent } from '~/tenants/tonsiteweb/router';

const tenant = resolveTenantFromRequest(Astro.request);
const url = new URL(Astro.request.url);
const planParam = (url.searchParams.get('plan') || '').toLowerCase();
const localePrefixMatch = url.pathname.match(/^\/(fr|en|de|it)(?=\/|$)/);
const localePrefix = localePrefixMatch ? `/${localePrefixMatch[1]}` : '';
if (tenant.slug === 'tonsiteweb' && planParam.startsWith('advanced')) {
  return Astro.redirect(`${localePrefix}/choose-template?model=backend_light&plan=avance`);
}

const TonComponent =
  tenant.slug === 'tonsiteweb'
    ? resolveTonSiteWebComponent('contact', Astro.url instanceof URL ? Astro.url : new URL(Astro.request.url), Astro.request)
    : null;

const hostCandidates = [
  Astro.request.headers.get('x-forwarded-host'),
  Astro.request.headers.get('host'),
  new URL(Astro.request.url).host,
]
  .flatMap((value) => (value || '').split(','))
  .map((value) => value.toLowerCase().trim().split(':')[0])
  .filter(Boolean);
const isToloHost = hostCandidates.some((host) => host.includes('tolocoiffure.ch'));
if (tenant.slug === 'tolo-coiffure' || isToloHost) {
  return Astro.rewrite('/tolo-coiffure/contact');
}

if (tenant.slug === 'ateliermemoire' && !(Astro.url?.pathname || '').startsWith('/atelier-memoire')) {
  const target = new URL('/atelier-memoire/contact', Astro.url instanceof URL ? Astro.url : new URL(Astro.request.url));
  return Astro.redirect(target.toString(), 308);
}

let lceData: {
  metadata: Record<string, any>;
  inputs: any[];
  textarea: any;
  disclaimer: string;
  button: string;
  title: string;
  subtitle: string;
} | null = null;

const host = Astro.request.headers.get('host');
const brandKey = getBrandFromHost(host) || 'pedro';
if (!TonComponent && brandKey === 'maisoncortes') {
  return Astro.redirect('/maison-cortes/contact');
}

const isUrgent = brandKey === 'urgent';
const isEtat = brandKey === 'etatdeslieux';
const isTransport = brandKey === 'transport';
const isLausanne = brandKey === 'lausanne' || tenant.slug === 'lausanne';
const brand = BRANDS[brandKey] || BRANDS.pedro;
const defaultLocale = brandKey === 'laclemanexperience' ? 'en' : 'fr';
const locale = resolveLocaleFromRequest(Astro.request, defaultLocale);
const lang =
  brandKey === 'laclemanexperience'
    ? (['fr', 'en', 'de', 'it', 'ar', 'zh'].includes(locale) ? locale : defaultLocale)
    : isLausanne
      ? (['fr', 'en', 'de', 'it'].includes(locale) ? locale : 'fr')
      : 'fr';
const isEn = lang === 'en';
const isDe = lang === 'de';
const isIt = lang === 'it';
const isAr = lang === 'ar';
const isZh = lang === 'zh';
const lceT = <T,>(fr: T, en: T, de: T, it: T, ar?: T, zh?: T): T => {
  if (brandKey !== 'laclemanexperience') return fr;
  if (isEn) return en;
  if (isDe) return de;
  if (isIt) return it;
  if (isAr && ar !== undefined) return ar;
  if (isZh && zh !== undefined) return zh;
  return fr;
};
const lamT = <T,>(fr: T, en: T, de: T, it: T): T => {
  if (!isLausanne) return fr;
  if (isEn) return en;
  if (isDe) return de;
  if (isIt) return it;
  return fr;
};

if (!TonComponent && tenant.slug === 'laclemanexperience') {
  const lceT = <T,>(fr: T, en: T, de: T, it: T): T => {
    if (isEn) return en;
    if (isDe) return de;
    if (isIt) return it;
    return fr;
  };

  const lceInputs = [
    { type: 'hidden', name: 'tenant', attributes: { value: 'laclemanexperience' } },
    { type: 'hidden', name: 'form_type', attributes: { value: 'experience_inquiry' } },
    { type: 'hidden', name: 'locale', attributes: { value: lang } },
    { type: 'hidden', name: 'source', attributes: { value: 'web' } },
    { name: 'name', label: lceT('Nom complet', 'Full name', 'Vollständiger Name', 'Nome completo'), required: true },
    { name: 'email', label: 'Email', type: 'email', required: true, placeholder: 'you@example.com' },
    { name: 'phone', label: lceT('Téléphone', 'Phone', 'Telefon', 'Telefono'), type: 'tel', placeholder: '+41 …' },
    {
      name: 'experience_type',
      label: lceT('Type d’expérience', 'Experience type', 'Erlebnistyp', 'Tipo di esperienza'),
      type: 'radio',
      required: true,
      colSpan: 2,
      options: [
        { value: 'private_cruise', label: lceT('Croisière privée', 'Private cruise', 'Private Cruise', 'Crociera privata') },
        { value: 'food_experience', label: lceT('Expérience gastronomique', 'Dining experience', 'Gastronomie-Erlebnis', 'Esperienza gastronomica') },
        { value: 'stay_weekend', label: lceT('Week-end / séjour', 'Weekend / stay', 'Weekend / Aufenthalt', 'Weekend / soggiorno') },
        { value: 'special_event', label: lceT('Événement spécial', 'Special event', 'Spezieller Anlass', 'Evento speciale') },
        { value: 'sur_mesure', label: lceT('Sur-mesure', 'Custom', 'Massgeschneidert', 'Su misura') },
        { value: 'other', label: lceT('Autre', 'Other', 'Andere', 'Altro') },
      ],
    },
    {
      type: 'textarea',
      name: 'experience_details',
      label: lceT('Pouvez-vous nous en dire un peu plus ?', 'Can you tell us a bit more?', 'Können Sie uns mehr erzählen?', 'Puoi dirci qualcosa di più?'),
      placeholder: lceT(
        'Ex : anniversaire, mariage, événement d’entreprise…',
        'e.g., birthday, wedding, corporate gathering…',
        'z.B. Geburtstag, Hochzeit, Firmenanlass…',
        'Es: compleanno, matrimonio, evento aziendale…'
      ),
      colSpan: 2,
      conditional: { source: 'experience_type', showOn: ['special_event'] },
    },
    {
      type: 'textarea',
      name: 'experience_details',
      label: lceT('Décrivez brièvement l’expérience idéale que vous imaginez', 'Describe the ideal experience you have in mind', 'Beschreiben Sie kurz Ihr Wunscherlebnis', "Descrivi brevemente l'esperienza ideale che immagini"),
      placeholder: lceT(
        'Ton, rythme, ambiance, moments clés…',
        'Tone, pace, ambiance, key moments…',
        'Ton, Rhythmus, Stimmung, Schlüsselmomente…',
        'Tono, ritmo, atmosfera, momenti chiave…'
      ),
      colSpan: 2,
      conditional: { source: 'experience_type', showOn: ['sur_mesure'] },
    },
    {
      type: 'textarea',
      name: 'experience_details',
      label: lceT('Précisez votre demande', 'Specify your request', 'Präzisieren Sie Ihre Anfrage', 'Precisa la tua richiesta'),
      placeholder: lceT('Ce que vous souhaitez vivre', 'What you’d like to experience', 'Was Sie erleben möchten', 'Cosa vorresti vivere'),
      colSpan: 2,
      conditional: { source: 'experience_type', showOn: ['other'] },
    },
    {
      name: 'date_from',
      label: lceT('Date souhaitée — début', 'Desired date — from', 'Gewünschtes Datum — ab', 'Data desiderata — inizio'),
      type: 'date',
      helper: lceT('Choisissez une date ou la première journée possible', 'Pick a date or the first possible day', 'Datum oder ersten Tag wählen', 'Scegli una data o il primo giorno possibile'),
    },
    {
      name: 'date_to',
      label: lceT('Date souhaitée — fin', 'Desired date — to', 'Gewünschtes Datum — bis', 'Data desiderata — fine'),
      type: 'date',
      helper: lceT('Facultatif : fin de votre fenêtre', 'Optional: end of your window', 'Optional: Ende Ihres Fensters', 'Opzionale: fine della finestra'),
    },
    {
      name: 'party_size',
      label: lceT('Nombre de personnes', 'Party size', 'Personenzahl', 'Numero di persone'),
      type: 'number',
      attributes: { min: 1, max: 30, step: 1 },
      required: true,
    },
    {
      name: 'dietary',
      label: lceT('Régimes / allergies', 'Dietary / allergies', 'Ernährung / Allergien', 'Diete / allergie'),
      placeholder: lceT('Ex: sans gluten, sans lactose', 'e.g., gluten-free, lactose-free', 'z.B. glutenfrei, laktosefrei', 'es. senza glutine, senza lattosio'),
    },
  ];

  const lceTextarea = {
    name: 'message',
    label: lceT('Votre demande', 'Your request', 'Ihre Anfrage', 'La tua richiesta'),
    placeholder: lceT(
      'Itinéraire souhaité, timing, préférences, contraintes…',
      'Desired itinerary, timing, preferences, constraints…',
      'Gewünschte Route, Timing, Präferenzen, Einschränkungen…',
      'Itinerario, tempistiche, preferenze, vincoli…'
    ),
    required: true,
  };

  const lceDisclaimer = lceT(
    'Réponse par concierge dédié sous 24h.',
    'Reply from a dedicated concierge within 24h.',
    'Antwort durch Concierge innert 24h.',
    'Risposta di un concierge dedicato entro 24h.'
  );

  const lceButton = lceT('Parler à un concierge', 'Talk to a concierge', 'Mit einem Concierge sprechen', 'Parlare con un concierge');
  const lceMetadata = { title: lceT('Contact — Lac Léman Experience', 'Contact — Lac Léman Experience', 'Kontakt — Lac Léman Experience', 'Contatto — Lac Léman Experience') };

  lceData = {
    metadata: lceMetadata,
    inputs: lceInputs,
    textarea: lceTextarea,
    disclaimer: lceDisclaimer,
    button: lceButton,
    title: lceT('Parlons de votre expérience', 'Tell us about your experience', 'Sprechen wir über Ihr Erlebnis', 'Parliamo della tua esperienza'),
    subtitle: lceT('Concierge dédié, options validées à l’avance.', 'Dedicated concierge, options validated upfront.', 'Dedizierter Concierge, Optionen im Voraus bestätigt.', 'Concierge dedicato, opzioni validate in anticipo.'),
  };
}

const brandType =
  isUrgent
    ? 'urgent'
    : brandKey === 'transport'
      ? 'transport'
      : brandKey === 'debarras'
        ? 'debarras'
        : brandKey === 'videmaison'
          ? 'videmaison'
          : brandKey === 'videsuccession'
            ? 'videsuccession'
            : brandKey === 'nettoyagesuccession' || brandKey === 'lausannenettoyage'
              ? 'clean'
              : brandKey === 'etatdeslieux'
                ? 'etatdeslieux'
                : brandKey === 'laclemanexperience'
                  ? 'experience'
                  : 'move';
const img = (id: ImageId) => getImage(id);
const contactBgId =
  brandKey === 'urgent'
    ? 'inside_truck_unloading_couch'
    : brandKey === 'lausanne'
      ? 'men_loading_van_3'
      : brandKey === 'transport'
        ? 'professional_van_2'
  : brandKey === 'debarras'
    ? 'van_inside_objects_boxes_1'
        : brandKey === 'videmaison'
          ? 'strong_man_packing_1'
          : brandKey === 'videsuccession'
            ? 'empty_apartment_7'
            : brandKey === 'nettoyagesuccession' || brandKey === 'lausannenettoyage'
              ? 'man_cleaning'
              : brandKey === 'etatdeslieux'
                ? 'empty_apartment_10'
              : brandKey === 'laclemanexperience'
              ? 'leman_horizon_minimal_2'
              : 'hero_happy_boxes_plants';
const contactAlt = getImageAlt(contactBgId);

