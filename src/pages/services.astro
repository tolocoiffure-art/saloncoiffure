---
import Shell from '~/tenants/tolo-coiffure/Shell.astro';
import { toloServicePanels, bookingCta } from '~/tenants/tolo-coiffure/services';
import { toloCoiffureConfig } from '~/tenants/tolo-coiffure/config';

const metadata = {
  title: 'Services — Tolo Coiffure Lausanne',
  description: 'Prestations femme et homme — grille complète et tarifs exacts en CHF.',
  ignoreTitleTemplate: true,
};

const tabOrder = ['femme', 'homme'] as const;
const serviceTabs = tabOrder.map((key) => ({
  key,
  ...toloServicePanels[key],
}));
---

<Shell page="services" metadata={metadata}>
  <section class="tc-section">
    <p class="tc-kicker">Prestations</p>
    <h1 class="tc-title">Services femme & homme</h1>
    <p class="tc-lead">
      Tarifs officiels en CHF. Navigation par onglets, affichage clair et lecture immédiate des prix.
    </p>
  </section>

  <section class="tc-section tc-services" data-tc-services>
    <div class="tc-tabs" data-tabs-root>
      <div class="tc-tablist tc-tablist-main" role="tablist" aria-label="Choix des prestations">
        {
          serviceTabs.map((tab, index) => (
            <button
              id={`tc-tab-${tab.key}`}
              type="button"
              role="tab"
              class={`tc-tab ${index === 0 ? 'is-active' : ''}`}
              aria-selected={index === 0 ? 'true' : 'false'}
              aria-controls={`tc-panel-${tab.key}`}
              tabindex={index === 0 ? '0' : '-1'}
              data-gender-tab-target={tab.key}
            >
              {tab.title}
            </button>
          ))
        }
      </div>

      <div class="tc-panels" data-gender-panels>
        {
          serviceTabs.map((tab, index) => (
            <section
              id={`tc-panel-${tab.key}`}
              role="tabpanel"
              aria-labelledby={`tc-tab-${tab.key}`}
              aria-hidden={index === 0 ? 'false' : 'true'}
              class={`tc-panel ${index === 0 ? 'is-active' : ''}`}
              data-gender-panel={tab.key}
              hidden={index !== 0}
            >
              <div class="tc-subtabs" data-subtabs-root={tab.key}>
                <div class="tc-tablist tc-tablist-sub" role="tablist" aria-label={`Catégories ${tab.title}`}>
                  {tab.categories.map((category, categoryIndex) => (
                    <button
                      id={`tc-subtab-${tab.key}-${categoryIndex}`}
                      type="button"
                      role="tab"
                      class={`tc-subtab ${categoryIndex === 0 ? 'is-active' : ''}`}
                      aria-selected={categoryIndex === 0 ? 'true' : 'false'}
                      aria-controls={`tc-subpanel-${tab.key}-${categoryIndex}`}
                      tabindex={categoryIndex === 0 ? '0' : '-1'}
                      data-category-tab-target={`${tab.key}-${categoryIndex}`}
                    >
                      {category.title}
                    </button>
                  ))}
                </div>

                <div class="tc-subpanels" data-category-panels>
                  {tab.categories.map((category, categoryIndex) => (
                    <section
                      id={`tc-subpanel-${tab.key}-${categoryIndex}`}
                      role="tabpanel"
                      aria-labelledby={`tc-subtab-${tab.key}-${categoryIndex}`}
                      aria-hidden={categoryIndex === 0 ? 'false' : 'true'}
                      class={`tc-category-panel ${categoryIndex === 0 ? 'is-active' : ''}`}
                      data-category-panel={`${tab.key}-${categoryIndex}`}
                      hidden={categoryIndex !== 0}
                    >
                      <header class="tc-category-head">
                        <h2>{category.title}</h2>
                      </header>

                      <div class="tc-card-grid">
                        {category.items.map((item) => (
                          <article class="tc-service-card">
                            <div class="tc-service-row">
                              <h3>{item.name}</h3>
                              <p class="tc-price">{item.price}</p>
                            </div>
                          </article>
                        ))}
                      </div>
                    </section>
                  ))}
                </div>
              </div>
            </section>
          ))
        }
      </div>

      <a class="tc-booking" href={toloCoiffureConfig.bookingUrl} target="_blank" rel="noreferrer">{bookingCta}</a>
    </div>
  </section>
</Shell>

<script>
  (() => {
    const bindTabs = (
      scope: ParentNode,
      tabSelector: string,
      panelSelector: string,
      tabKeyAttr: string,
      panelKeyAttr: string
    ) => {
      const tabs = Array.from(scope.querySelectorAll<HTMLButtonElement>(tabSelector));
      const panels = Array.from(scope.querySelectorAll<HTMLElement>(panelSelector));
      if (!tabs.length || !panels.length) return null;

      const keyFromTab = (tab: HTMLButtonElement) => tab.getAttribute(tabKeyAttr) || '';
      const keyFromPanel = (panel: HTMLElement) => panel.getAttribute(panelKeyAttr) || '';

      let activeKey = keyFromTab(tabs.find((tab) => tab.getAttribute('aria-selected') === 'true') || tabs[0]);

      const applyTabState = (selectedKey: string, focusSelected: boolean) => {
        tabs.forEach((tab) => {
          const isSelected = keyFromTab(tab) === selectedKey;
          tab.setAttribute('aria-selected', String(isSelected));
          tab.tabIndex = isSelected ? 0 : -1;
          tab.classList.toggle('is-active', isSelected);
          if (focusSelected && isSelected) tab.focus();
        });
      };

      const applyPanelState = (selectedKey: string) => {
        panels.forEach((panel) => {
          const isSelected = keyFromPanel(panel) === selectedKey;
          panel.hidden = !isSelected;
          panel.setAttribute('aria-hidden', String(!isSelected));
          panel.classList.toggle('is-active', isSelected);
        });
      };

      const activate = (nextKey: string, focusSelected = false) => {
        if (!nextKey) return;
        activeKey = nextKey;
        applyTabState(nextKey, focusSelected);
        applyPanelState(nextKey);
      };

      tabs.forEach((tab) => {
        tab.addEventListener('click', () => activate(keyFromTab(tab), false));
        tab.addEventListener('keydown', (event: KeyboardEvent) => {
          const currentIndex = tabs.indexOf(tab);
          if (currentIndex === -1) return;

          if (event.key === 'ArrowRight' || event.key === 'ArrowLeft') {
            event.preventDefault();
            const direction = event.key === 'ArrowRight' ? 1 : -1;
            const nextIndex = (currentIndex + direction + tabs.length) % tabs.length;
            activate(keyFromTab(tabs[nextIndex]), true);
            return;
          }

          if (event.key === 'Home' || event.key === 'End') {
            event.preventDefault();
            const nextIndex = event.key === 'Home' ? 0 : tabs.length - 1;
            activate(keyFromTab(tabs[nextIndex]), true);
          }
        });
      });

      activate(activeKey, false);
      return { activate };
    };

    const initTabs = () => {
      const root = document.querySelector<HTMLElement>('[data-tabs-root]');
      if (!root || root.dataset.tabsBound === 'true') return;
      root.dataset.tabsBound = 'true';

      bindTabs(root, '[data-gender-tab-target]', '[data-gender-panel]', 'data-gender-tab-target', 'data-gender-panel');
      root.querySelectorAll<HTMLElement>('[data-subtabs-root]').forEach((subRoot) => {
        bindTabs(
          subRoot,
          '[data-category-tab-target]',
          '[data-category-panel]',
          'data-category-tab-target',
          'data-category-panel'
        );
      });
    };

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initTabs, { once: true });
    } else {
      initTabs();
    }
    document.addEventListener('astro:page-load', initTabs);
  })();
</script>

<style>
  .tc-section {
    margin-bottom: 88px;
  }
  .tc-kicker {
    letter-spacing: 0.14em;
    text-transform: uppercase;
    font-size: 0.8rem;
    color: #4b5563;
  }
  .tc-title {
    font-family: var(--tc-font-heading);
    font-size: clamp(2rem, 3.8vw, 2.5rem);
    margin: 0.25rem 0 0.8rem;
    letter-spacing: -0.012em;
  }
  .tc-lead {
    max-width: 800px;
    color: #374151;
    font-size: 1rem;
    line-height: 1.7;
  }

  .tc-tabs {
    display: grid;
    gap: 1.75rem;
  }

  .tc-tablist {
    display: inline-flex;
    align-items: center;
  }

  .tc-tablist-main {
    gap: 0.4rem;
    width: fit-content;
    border: 1px solid color-mix(in srgb, var(--tc-line) 86%, var(--tc-accent) 14%);
    border-radius: 999px;
    background: color-mix(in srgb, #ffffff 72%, var(--tc-bg) 28%);
    padding: 0.35rem;
    box-shadow: 0 18px 38px -34px rgba(43, 29, 20, 0.34);
  }

  .tc-tab {
    appearance: none;
    border: 0;
    border-radius: 999px;
    background: transparent;
    color: color-mix(in srgb, var(--tc-text) 90%, #000 10%);
    font-size: 0.9rem;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    font-weight: 600;
    padding: 0.6rem 1.1rem;
    cursor: pointer;
    transition:
      background-color 240ms ease,
      color 240ms ease;
  }

  .tc-tab:hover {
    background: color-mix(in srgb, var(--tc-accent) 14%, #ffffff 86%);
  }

  .tc-tab:focus-visible {
    outline: 2px solid color-mix(in srgb, var(--tc-accent) 80%, var(--tc-text) 20%);
    outline-offset: 2px;
  }

  .tc-tab.is-active {
    background: linear-gradient(
      135deg,
      color-mix(in srgb, var(--tc-dark) 80%, var(--tc-accent) 20%),
      color-mix(in srgb, var(--tc-dark) 92%, var(--tc-accent) 8%)
    );
    color: #f5efe8;
    box-shadow: inset 0 0 0 1px color-mix(in srgb, var(--tc-accent) 42%, transparent);
  }

  .tc-panels {
    position: relative;
    transition: min-height 240ms ease;
  }

  .tc-panel {
    display: grid;
    gap: 1.25rem;
    opacity: 1;
    transform: translateY(0);
    transition:
      opacity 240ms ease,
      transform 240ms ease;
  }

  .tc-panel.is-enter {
    opacity: 0;
    transform: translateY(8px);
  }

  .tc-panel.is-exit {
    opacity: 0;
    transform: translateY(-4px);
  }

  .tc-panel.is-measuring {
    position: absolute;
    inset: 0;
    width: 100%;
    pointer-events: none;
    visibility: hidden;
  }

  .tc-subtabs {
    display: grid;
    gap: 1.2rem;
  }

  .tc-tablist-sub {
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem;
    align-items: center;
  }

  .tc-subtab {
    appearance: none;
    border: 1px solid color-mix(in srgb, var(--tc-line) 84%, var(--tc-accent) 16%);
    border-radius: 999px;
    background: color-mix(in srgb, #ffffff 84%, var(--tc-bg) 16%);
    color: color-mix(in srgb, var(--tc-text) 92%, #000 8%);
    font-size: 0.78rem;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    font-weight: 600;
    padding: 0.5rem 0.85rem;
    cursor: pointer;
    transition:
      background-color 220ms ease,
      color 220ms ease,
      border-color 220ms ease;
  }

  .tc-subtab:hover {
    border-color: color-mix(in srgb, var(--tc-accent) 52%, var(--tc-line) 48%);
    background: color-mix(in srgb, var(--tc-accent) 12%, #ffffff 88%);
  }

  .tc-subtab:focus-visible {
    outline: 2px solid color-mix(in srgb, var(--tc-accent) 80%, var(--tc-text) 20%);
    outline-offset: 2px;
  }

  .tc-subtab.is-active {
    background: color-mix(in srgb, var(--tc-accent) 18%, var(--tc-dark) 82%);
    color: #f5efe8;
    border-color: color-mix(in srgb, var(--tc-accent) 68%, var(--tc-dark) 32%);
    box-shadow: inset 0 0 0 1px color-mix(in srgb, var(--tc-accent) 32%, transparent);
  }

  .tc-subpanels {
    position: relative;
  }

  .tc-category-panel {
    display: grid;
    gap: 1rem;
  }

  .tc-panel[hidden],
  .tc-category-panel[hidden] {
    display: none !important;
  }

  .tc-category-head h2 {
    margin: 0;
    font-family: var(--tc-font-heading);
    letter-spacing: -0.01em;
    font-size: clamp(1.35rem, 2.4vw, 1.55rem);
    color: color-mix(in srgb, var(--tc-text) 94%, #000 6%);
    padding-bottom: 0.45rem;
    border-bottom: 1px solid color-mix(in srgb, var(--tc-line) 70%, transparent);
  }

  .tc-card-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.9rem;
  }

  .tc-service-card {
    background: #ffffff;
    border: 1px solid color-mix(in srgb, var(--tc-line) 78%, var(--tc-accent) 22%);
    border-radius: 14px;
    padding: 1.05rem 1.1rem;
    display: grid;
    gap: 0.35rem;
    min-height: 96px;
    box-shadow: 0 16px 34px -32px rgba(43, 29, 20, 0.42);
    transition:
      transform 180ms ease,
      box-shadow 180ms ease,
      border-color 180ms ease;
  }

  .tc-service-card:hover {
    transform: translateY(-1px);
    border-color: color-mix(in srgb, var(--tc-accent) 48%, var(--tc-line) 52%);
    box-shadow: 0 20px 42px -32px rgba(43, 29, 20, 0.5);
  }

  .tc-service-row {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    gap: 0.75rem;
    align-items: start;
  }

  .tc-service-row h3 {
    margin: 0;
    letter-spacing: -0.005em;
    font-size: 1rem;
    line-height: 1.45;
    color: color-mix(in srgb, var(--tc-text) 95%, #000 5%);
  }

  .tc-price {
    margin: 0;
    white-space: nowrap;
    font-weight: 700;
    color: var(--tc-dark);
    font-size: 0.98rem;
    letter-spacing: 0.015em;
  }

  .tc-booking {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: fit-content;
    padding: 0.7rem 1.25rem;
    border-radius: 999px;
    border: 1px solid #111827;
    color: #111827;
    background: #ffffff;
    text-decoration: none;
    transition:
      background-color 240ms ease,
      color 240ms ease;
  }

  .tc-booking:hover {
    background: #111827;
    color: #ffffff;
  }

  .tc-booking:focus-visible {
    outline: 2px solid #111827;
    outline-offset: 2px;
  }

  @media (max-width: 960px) {
    .tc-card-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 640px) {
    .tc-section {
      margin-bottom: 72px;
    }

    .tc-tablist-main {
      width: 100%;
      justify-content: space-between;
    }

    .tc-tab {
      flex: 1 1 0;
      text-align: center;
    }

    .tc-subtab {
      text-align: center;
      width: 100%;
    }
  }
</style>
