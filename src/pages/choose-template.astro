---
import Layout from '~/layouts/PageLayout.astro';
import Headline from '~/components/ui/Headline.astro';
import { TENANTS } from '~/lib/tenants';
import { BRANDS } from '~/lib/brands.config';
import type { BrandKey } from '~/lib/brand';
import { getImage, type ImageId } from '~/data/imageInventory';
import toloTemplateImage from '~/assets/tolocoiffure_images/template_preview.jpg';
import atelierMemoireTemplateImage from '~/assets/tolocoiffure_images/distinguished_middle_age_man.png';
import { resolveLocaleFromRequest } from '~/lib/locale';
import { resolveTenantFromRequest } from '~/lib/tenants';
import { buildHeaderData, buildFooterData } from '~/navigation';
import { TEMPLATE_DEFINITIONS, type PlanCode, type TemplateModel } from '~/data/templates';

const rawPlan = Astro.url.searchParams.get('plan') || '';
const normalizePlan = (value: string): PlanCode | string => {
  if (!value) return '';
  const cleaned = value.replace(/essential/i, '').replace(/[^\dA-Za-z]/g, '');
  if (['999', '1249', '1500', 'avance'].includes(cleaned)) return cleaned as PlanCode;
  if (cleaned === '1500') return '1500';
  return value;
};
const plan = normalizePlan(rawPlan);
const modelParam = (Astro.url.searchParams.get('model') || '').trim().toLowerCase();
const currentUrl = Astro.url instanceof URL ? Astro.url : new URL(Astro.request.url);
const rawTier = (currentUrl.searchParams.get('tier') || '').toLowerCase();
const entryPlans: PlanCode[] = ['999', '1249', '1500'];
const entryModels: TemplateModel[] = ['frontend'];
const advancedModels: TemplateModel[] = ['backend_light', 'backend_heavy', 'engine', 'experience', 'boutique'];
const modelFromPlan: TemplateModel | '' =
  plan === '999' || plan === '1249' || plan === '1500'
    ? 'frontend'
    : plan === 'avance'
      ? 'backend_light'
      : '';
const planTier: 'entry' | 'advanced' | '' =
  entryPlans.includes(plan as PlanCode) ? 'entry' : plan === 'avance' ? 'advanced' : '';
const tierDefault: 'entry' | 'advanced' | 'all' = planTier === 'entry' ? 'all' : planTier === 'advanced' ? 'all' : 'all';
const tierFilter: 'entry' | 'advanced' | 'all' =
  rawTier === 'entry' || rawTier === 'advanced' ? (rawTier as 'entry' | 'advanced') : tierDefault;
const showEntryTier = tierFilter !== 'advanced';
const showAdvancedTier = tierFilter !== 'entry';

const model = (['frontend', 'experience', 'boutique', 'backend_light', 'backend_heavy', 'engine'].includes(modelParam)
  ? (planTier === 'entry' ? 'frontend' : (modelParam as TemplateModel))
  : planTier === 'entry'
    ? 'frontend'
    : modelFromPlan) || '';
const locale = resolveLocaleFromRequest(Astro.request, 'fr');
const tenant = resolveTenantFromRequest(Astro.request);
const brandKeyForPage = (tenant.brandKey || tenant.slug || 'pedro') as BrandKey;
const brandForPage = BRANDS[brandKeyForPage] || BRANDS.pedro;
const header = buildHeaderData({ ...brandForPage, key: brandKeyForPage }, locale);
const footer = buildFooterData({ ...brandForPage, key: brandKeyForPage }, locale);

type Tier = 'entry' | 'advanced';

type TemplateCard = {
  id: string;
  name: string;
  description: string;
  previewUrl: string;
  domainLabel: string;
  primary?: string;
  accent?: string;
  tier: Tier;
  locked?: boolean;
  image?: { src: string; alt?: string };
};

const tenantBySlug = Object.fromEntries(TENANTS.map((t) => [t.slug, t]));
const templates: TemplateCard[] = [];

const tenantCopy: Record<
  string,
  {
  name?: Partial<Record<'en' | 'de' | 'it', string>>;
  description?: Partial<Record<'en' | 'de' | 'it', string>>;
  }
> = {
  debarras: {
    name: { en: 'Clear-Out Lausanne', de: 'Entrümpelung Lausanne', it: 'Sgombero Lausanne' },
    description: {
      en: 'Apartment, cellar and local clear-outs in Lausanne. Fast sorting, handling and removal.',
      de: 'Wohnungen, Keller und Räume räumen in Lausanne. Schnelles Sortieren, Tragen und Entsorgen.',
      it: 'Sgombero di appartamenti, cantine e locali a Losanna. Smistamento, movimentazione e smaltimento rapidi.',
    },
  },
  etatdeslieux: {
    name: { en: 'Move-In/Out Reports', de: 'Wohnungsabnahmen', it: 'Stati dei luoghi' },
    description: {
      en: 'Rental inspections with photo reports and quick turnaround.',
      de: 'Mietabnahmen mit Fotoreport und kurzer Frist.',
      it: 'Verbali di stato locativo con report fotografico e consegna rapida.',
    },
  },
  laclemanexperience: {
    name: { en: 'Lac Léman Experience', de: 'Lac Léman Experience', it: 'Lac Léman Experience' },
    description: {
      en: 'Sunset cruises, UNESCO vineyards, hosted tables and alpine escapes.',
      de: 'Sunset-Cruises, UNESCO-Weinberge, Gastgebertafeln und alpine Ausflüge.',
      it: 'Crociera al tramonto, vigneti UNESCO, tavole d’hôtes e fughe alpine.',
    },
  },
  lausanne: {
    name: { en: 'Lausanne Moving', de: 'Umzug Lausanne', it: 'Traslochi Losanna' },
    description: {
      en: 'City access secured, pro protection, transparent service across Vaud.',
      de: 'Stadtzugang gesichert, Profi-Schutz, transparenter Service in Waadt.',
      it: 'Accessi cittadini garantiti, protezioni pro e servizio trasparente nel Vaud.',
    },
  },
  maisoncortes: {
    name: { en: 'Maison Cortes', de: 'Maison Cortes', it: 'Maison Cortes' },
    description: {
      en: 'Short selection of architectural brass objects. CHF only.',
      de: 'Kurze Auswahl architektonischer Objekte in Messing. Nur CHF.',
      it: 'Selezione corta di oggetti architettonici in ottone. Solo CHF.',
    },
  },
  nettoyagesuccession: {
    name: { en: 'Estate Cleaning', de: 'Nachlassreinigung', it: 'Pulizia successione' },
    description: {
      en: 'Full cleaning after succession, ready to rent or sell.',
      de: 'Komplettreinigung nach Nachlass, bezugs- oder verkaufsbereit.',
      it: 'Pulizia completa dopo successione, pronta per affitto o vendita.',
    },
  },
  lausannenettoyage: {
    name: { en: 'Cleaning Lausanne', de: 'Reinigung Lausanne', it: 'Pulizie Losanna' },
    description: {
      en: 'Full cleaning in Lausanne: end-of-lease, offices, post-renovation.',
      de: 'Komplettreinigung in Lausanne: Auszug, Büros, nach Bauarbeiten.',
      it: 'Pulizie complete a Losanna: fine locazione, uffici, post-lavori.',
    },
  },
  tonsiteweb: {
    name: { en: 'TonSiteWeb', de: 'TonSiteWeb', it: 'TonSiteWeb' },
    description: {
      en: 'Turnkey showcase sites for SMEs and independents in the Léman region.',
      de: 'Schlüsselfertige Web-Showcases für KMU und Selbständige am Genfersee.',
      it: 'Siti vetrina chiavi in mano per PMI e indipendenti nella regione lemanica.',
    },
  },
  transport: {
    name: { en: 'Furniture Transport', de: 'Möbeltransport', it: 'Trasporto mobili' },
    description: {
      en: 'Secured furniture transport, packing and reinforced lashing.',
      de: 'Sicherer Möbeltransport, Verpackung und verstauter Zurr.',
      it: 'Trasporto mobili sicuro, imballaggio e fissaggio rinforzato.',
    },
  },
  urgent: {
    name: { en: 'Urgent Move', de: 'Dringender Umzug', it: 'Trasloco urgente' },
    description: {
      en: 'Fast response moves in Suisse romande with trained crew and protected access.',
      de: 'Schnelle Umzüge in der Romandie mit geschultem Team und geschützten Zugängen.',
      it: 'Traslochi rapidi in Svizzera romanda con squadra formata e accessi protetti.',
    },
  },
  videmaison: {
    name: { en: 'House Clearance', de: 'Haushaltsauflösung', it: 'Sgombero casa' },
    description: {
      en: 'Full house clearance, sorting and quick removal with protection.',
      de: 'Komplette Haushaltsauflösung, Sortierung und zügige Räumung mit Schutz.',
      it: 'Sgombero completo, smistamento e rimozione rapida con protezioni.',
    },
  },
  videsuccession: {
    name: { en: 'Succession Clearance', de: 'Nachlassräumung', it: 'Sgombero successione' },
    description: {
      en: 'Sorting, clearance and admin coordination for estates.',
      de: 'Sortierung, Räumung und administrative Koordination bei Nachlässen.',
      it: 'Smistamento, sgombero e coordinamento pratiche per successioni.',
    },
  },
  pedro: {
    name: { en: 'Pedro Moving', de: 'Pedro Umzug', it: 'Pedro Traslochi' },
    description: {
      en: 'Local team with full protection and controlled planning in Suisse romande.',
      de: 'Lokales Team mit vollem Schutz und geplantem Ablauf in der Romandie.',
      it: 'Team locale, protezioni complete e pianificazione controllata in Svizzera romanda.',
    },
  },
};

const imageBySlug: Record<string, ImageId> = {
  pedro: 'men_loading_e_cat_truck',
  lausanne: 'e_cat_truck_mountains_lake_00',
  urgent: 'van_moving_swiss_town_raining_motion_blur',
  debarras: 'studio_photo_hero_men_carrying_big_trolley_advertisement',
  transport: 'professional_van_3',
  videmaison: 'professional_van_5',
  videsuccession: 'high_end_luxury_apartment_lakeside',
  nettoyagesuccession: 'happy_female_customer_service',
  etatdeslieux: 'high_end_luxury_apartment_lakeside',
  lausannenettoyage: 'operator_pallet_unloading',
  laclemanexperience: 'high_luxury_swiss_balcony_leman',
  maisoncortes: 'high_end_luxury_apartment_lakeside',
  'maison-cortes': 'high_end_luxury_apartment_lakeside',
  tonsiteweb: 'hero_happy_boxes_plants',
};
const toImageSrc = (asset: string | { src: string }) => (typeof asset === 'string' ? asset : asset.src);
const localImageBySlug: Record<string, { src: string; alt: string }> = {
  'tolo-coiffure': {
    src: toImageSrc(toloTemplateImage as string | { src: string }),
    alt: 'Tolo Coiffure - balayage signature Lausanne',
  },
  ateliermemoire: {
    src: toImageSrc(atelierMemoireTemplateImage as string | { src: string }),
    alt: 'Atelier Memoire - portrait homme confiant',
  },
};

const allowEmptyPlan = !plan || (model && model !== 'frontend');

for (const def of TEMPLATE_DEFINITIONS) {
  const tenant = tenantBySlug[def.id];
  if (!tenant) continue;
  const brandKey = (tenant.brandKey || tenant.slug) as BrandKey;
  const brand = BRANDS[brandKey];
  if (!brand) continue;

  const tier: Tier =
    def.plans.length === 0
      ? 'advanced'
      : def.plans.some((p) => entryPlans.includes(p as PlanCode))
        ? 'entry'
        : 'advanced';

  const matchesTier = (tier === 'entry' && showEntryTier) || (tier === 'advanced' && showAdvancedTier);
  if (!matchesTier) continue;

  const modelMatches =
    !model ||
    def.models.includes(model as TemplateModel) ||
    (tier === 'entry' && planTier === 'advanced' && showEntryTier) ||
    (tier === 'advanced' && planTier === 'entry' && showAdvancedTier) ||
    (tier === 'advanced' && modelFromPlan === '' && showAdvancedTier);
  if (!modelMatches) continue;

  if (plan) {
    const hasPlans = def.plans && def.plans.length > 0;
    const acceptsEntryWhileOnAdvanced = plan === 'avance' && tier === 'entry';
    const acceptsAdvancedWhileOnEntry = planTier === 'entry' && tier === 'advanced';
    if (hasPlans && !def.plans.includes(plan as PlanCode) && !acceptsEntryWhileOnAdvanced && !acceptsAdvancedWhileOnEntry) continue;
    if (!hasPlans && !allowEmptyPlan) continue;
  }

  const domain = tenant.domains?.[0] || brand.domain || '';
  // Temporary switch requested for demo day: use HTTP preview links.
  const base = domain ? `http://${domain}` : '';
  const previewUrl = `${base}${tenant.basePath || ''}` || `/${tenant.slug}`;

  const externalImage =
    brand.key === 'maisoncortes'
      ? 'https://cdn.midjourney.com/4cb9eabb-b075-4bb0-a6ce-be83eeb43216/0_1.png'
      : undefined;

  templates.push({
    id: tenant.slug,
    name: tenantCopy[brand.key]?.name?.[locale as 'en' | 'de' | 'it'] || brand.shortName || brand.name,
    description: tenantCopy[brand.key]?.description?.[locale as 'en' | 'de' | 'it'] || brand.seoDescription || brand.name,
    previewUrl,
    domainLabel: domain || tenant.slug,
    primary: brand.primaryColor,
    accent: brand.secondaryColor || brand.theme?.accent,
    tier,
    locked: tier === 'advanced' && planTier === 'entry',
    image: (() => {
      const localImage = localImageBySlug[tenant.slug] || localImageBySlug[brand.key];
      if (localImage) return localImage;
      if (externalImage) return { src: externalImage, alt: brand.name };
      const imgId = imageBySlug[brand.key] || imageBySlug[tenant.slug];
      if (!imgId) return undefined;
      return { src: getImage(imgId), alt: brand.name };
    })(),
  });
}

const templateOrder: string[] = [
  'laclemanexperience',
  'maison-cortes',
  'tonsiteweb',
  'lausanne',
  'ateliermemoire',
  'tolo-coiffure',
  'etatdeslieux',
  'debarras',
  'urgent',
  'videsuccession',
  'transport',
  'videmaison',
  'lausannenettoyage',
  'nettoyagesuccession',
  'pedro',
];
const orderIndex = new Map(templateOrder.map((id, index) => [id, index]));

templates.sort((a, b) => {
  const aIndex = orderIndex.get(a.id) ?? Number.MAX_SAFE_INTEGER;
  const bIndex = orderIndex.get(b.id) ?? Number.MAX_SAFE_INTEGER;
  if (aIndex !== bIndex) return aIndex - bIndex;
  return a.name.localeCompare(b.name);
});

const planLabel = plan ? (plan === 'avance' ? 'Avancé' : `CHF ${plan}`) : '';
const modelLabel = model ? model : '';

const labels = {
  title: {
    fr: 'Choisissez votre modèle',
    en: 'Choose your template',
    de: 'Wählen Sie Ihr Modell',
    it: 'Scegli il tuo modello',
  },
  subtitle: {
    fr: planLabel
      ? `Plan sélectionné : ${planLabel}${modelLabel ? ` · modèle ${modelLabel}` : ''}`
      : 'Sélectionnez un pack sur la page Tarifs avant de confirmer.',
    en: planLabel
      ? `Selected plan: ${planLabel}${modelLabel ? ` · model ${modelLabel}` : ''}`
      : 'Pick a plan on the Pricing page first.',
    de: planLabel
      ? `Gewählter Plan: ${planLabel}${modelLabel ? ` · Modell ${modelLabel}` : ''}`
      : 'Wählen Sie zuerst ein Paket auf der Preisseite.',
    it: planLabel
      ? `Piano selezionato: ${planLabel}${modelLabel ? ` · modello ${modelLabel}` : ''}`
      : 'Seleziona prima un pacchetto nella pagina Prezzi.',
  },
  preview: {
    fr: 'Prévisualiser',
    en: 'Preview',
    de: 'Vorschau',
    it: 'Anteprima',
  },
  select: {
    fr: 'Sélectionner',
    en: 'Select',
    de: 'Auswählen',
    it: 'Seleziona',
  },
  filters: {
    fr: { label: 'Filtrer', all: 'Avancé + Essentiel', advanced: 'Avancé (≤5 000 CHF)', entry: 'Essentiel (999–1 500 CHF)' },
    en: { label: 'Filter', all: 'Advanced + Essential', advanced: 'Advanced (≤5k CHF)', entry: 'Essential (999–1,500 CHF)' },
    de: { label: 'Filtern', all: 'Advanced + Essential', advanced: 'Advanced (≤5’000 CHF)', entry: 'Essential (999–1’500 CHF)' },
    it: { label: 'Filtra', all: 'Avanzato + Essenziale', advanced: 'Avanzato (≤5 000 CHF)', entry: 'Essenziale (999–1 500 CHF)' },
  },
  ribbons: {
    advanced: {
      fr: 'Pack Avancé · ≤5 000 CHF',
      en: 'Advanced pack · up to 5k CHF',
      de: 'Advanced-Paket · bis 5’000 CHF',
      it: 'Pacchetto Avanzato · fino a 5k CHF',
    },
    entry: {
      fr: 'Disponible en Essentiel',
      en: 'Also in Essential',
      de: 'Auch als Essential',
      it: 'Disponibile in Essenziale',
    },
  },
  tooltips: {
    entry: {
      fr: 'Existe dans le pack Essentiel (999–1 500 CHF). Idéal pour un site vitrine simple + formulaire email. Passez au pack Avancé si vous devez stocker des comptes ou automatiser des actions.',
      en: 'Available on the Essential tier (999–1,500 CHF). Great for a simple showcase + email form. Choose Advanced if you need user accounts, data storage or more complex automations.',
      de: 'Im Essential-Paket (999–1’500 CHF) verfügbar. Perfekt für eine einfache Vitrine mit Formular. Wählen Sie Advanced, wenn Sie Benutzerkonten, Datenspeicherung oder komplexere Automationen brauchen.',
      it: 'Disponibile nel piano Essenziale (999–1’500 CHF). Perfetto per un sito vetrina semplice + form email. Scegli Avanzato se ti servono account utente, storage o automazioni più complesse.',
    },
    advancedLocked: {
      fr: 'Disponible dès le pack Avancé (≤5 000 CHF). Passez au pack Avancé pour débloquer ce modèle et les automatisations associées.',
      en: 'Available from the Advanced pack (up to 5k CHF). Upgrade to Advanced to unlock this template and its automations.',
      de: 'Verfügbar ab dem Advanced-Paket (bis 5’000 CHF). Wechseln Sie zu Advanced, um diese Vorlage und die Automationen freizuschalten.',
      it: 'Disponibile dal pacchetto Avanzato (fino a 5k CHF). Passa ad Avanzato per sbloccare questo template e le sue automazioni.',
    },
  },
  upgradeCta: {
    fr: 'Passer au pack Avancé',
    en: 'Upgrade to Advanced',
    de: 'Zu Advanced wechseln',
    it: 'Passa ad Avanzato',
  },
  empty: {
    fr: 'Aucun modèle ne correspond à ce plan. Parlez à un expert pour un projet sur-mesure.',
    en: 'No template matches this plan. Talk to an expert for a custom project.',
    de: 'Kein Modell passt zu diesem Plan. Sprechen Sie mit einem Experten für ein maßgeschneidertes Projekt.',
    it: 'Nessun modello corrisponde a questo piano. Parla con un esperto per un progetto su misura.',
  },
};

const translate = (key: keyof typeof labels) => labels[key][(locale as 'fr' | 'en' | 'de' | 'it') || 'fr'];

const buildSelectUrl = (id: string) => {
  const params = new URLSearchParams();
  if (plan) params.set('plan', plan);
  if (model) params.set('model', model);
  params.set('template', id);
  return `/auth/signup?${params.toString()}`;
};

const buildTierHref = (tier: 'all' | 'advanced' | 'entry') => {
  const params = new URLSearchParams();
  if (plan) params.set('plan', plan);
  if (modelParam) params.set('model', modelParam);
  if (tier !== tierDefault) params.set('tier', tier);
  const qs = params.toString();
  return `${currentUrl.pathname}${qs ? `?${qs}` : ''}`;
};

const buildUpgradeUrl = () => {
  const params = new URLSearchParams();
  params.set('plan', 'avance');
  return `/pricing?${params.toString()}#modal-advanced`;
};

const metadata = { title: labels.title[locale as 'fr' | 'en' | 'de' | 'it'] || labels.title.fr };
---

<Layout metadata={metadata} header={header} footer={footer}>
  <div class="max-w-6xl mx-auto px-4 py-10 space-y-6">
    <Headline title={translate('title')} subtitle={translate('subtitle')} />

    {planTier === 'advanced' ? (
      <div class="flex flex-wrap items-center gap-2 text-sm text-slate-600 dark:text-slate-300">
        <span class="font-medium">{labels.filters[locale as 'fr' | 'en' | 'de' | 'it'].label}</span>
        {[
          { value: 'all', label: labels.filters[locale as 'fr' | 'en' | 'de' | 'it'].all },
          { value: 'advanced', label: labels.filters[locale as 'fr' | 'en' | 'de' | 'it'].advanced },
          { value: 'entry', label: labels.filters[locale as 'fr' | 'en' | 'de' | 'it'].entry },
        ].map((opt) => {
          const isActive = tierFilter === opt.value;
          return (
            <a
              href={buildTierHref(opt.value as 'all' | 'advanced' | 'entry')}
              class={`inline-flex items-center gap-1 rounded-full border px-3 py-1 transition ${
                isActive
                  ? 'border-slate-900 bg-slate-900 text-white dark:border-slate-100 dark:bg-slate-100 dark:text-slate-900'
                  : 'border-slate-200 text-slate-700 hover:border-slate-300 hover:text-slate-900 dark:border-slate-700 dark:text-slate-200 dark:hover:border-slate-600'
              }`}
            >
              {opt.label}
            </a>
          );
        })}
      </div>
    ) : (
      ''
    )}

    {templates.length === 0 ? (
      <div class="rounded-2xl border border-amber-200 bg-amber-50 text-amber-900 px-5 py-4 text-sm shadow-sm">
        {translate('empty')}
      </div>
    ) : (
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {templates.map((tpl) => (
          <article
            class={`rounded-2xl border border-slate-200/80 dark:border-slate-800 bg-white dark:bg-slate-900 shadow-sm overflow-hidden flex flex-col transition-transform duration-200 hover:-translate-y-1 hover:shadow-xl ${
              tpl.locked ? 'opacity-85' : ''
            }`}
            style={tpl.primary ? `--tpl-primary:${tpl.primary}; --tpl-accent:${tpl.accent || tpl.primary};` : ''}
          >
            <div class="h-36 relative overflow-hidden">
              {tpl.tier === 'advanced' ? (
                <span class="absolute top-3 left-3 z-10 rounded-full bg-red-600 px-3 py-1 text-[11px] font-semibold uppercase tracking-wide text-white shadow-md">
                  {labels.ribbons.advanced[locale as 'fr' | 'en' | 'de' | 'it']}
                </span>
              ) : planTier === 'advanced' ? (
                <span
                  class="absolute top-3 left-3 z-10 rounded-full border border-slate-200/80 bg-white/90 px-3 py-1 text-[11px] font-semibold uppercase tracking-wide text-slate-800 shadow-sm backdrop-blur"
                  title={labels.tooltips.entry[locale as 'fr' | 'en' | 'de' | 'it']}
                >
                  {labels.ribbons.entry[locale as 'fr' | 'en' | 'de' | 'it']}
                </span>
              ) : (
                ''
              )}
              {tpl.locked ? (
                <span
                  class="absolute top-3 right-3 z-10 rounded-full border border-slate-200/80 bg-white/90 px-3 py-1 text-[11px] font-semibold uppercase tracking-wide text-slate-800 shadow-sm backdrop-blur"
                  title={labels.tooltips.advancedLocked[locale as 'fr' | 'en' | 'de' | 'it']}
                >
                  {labels.upgradeCta[locale as 'fr' | 'en' | 'de' | 'it']}
                </span>
              ) : (
                ''
              )}
              {tpl.locked ? <div class="absolute inset-0 bg-white/60 dark:bg-slate-900/60 backdrop-blur-[1px]"></div> : ''}
              {tpl.image ? (
                <>
                  <img
                    src={tpl.image.src}
                    alt={tpl.image.alt || tpl.name}
                    class={`absolute inset-0 h-full w-full object-cover transition ${
                      tpl.locked ? 'filter grayscale contrast-90' : ''
                    }`}
                    loading="lazy"
                    title={
                      tpl.locked
                        ? labels.tooltips.advancedLocked[locale as 'fr' | 'en' | 'de' | 'it']
                        : tpl.tier === 'entry' && planTier === 'advanced'
                          ? labels.tooltips.entry[locale as 'fr' | 'en' | 'de' | 'it']
                          : undefined
                    }
                  />
                  <div class="absolute inset-0 bg-gradient-to-t from-black/45 via-black/20 to-transparent"></div>
                </>
              ) : (
                <div class="absolute inset-0 bg-gradient-to-br from-[var(--tpl-primary,#0f172a)] via-[var(--tpl-accent,#2563eb)] to-[var(--tpl-primary,#0f172a)]"></div>
              )}
              <div class="relative h-full w-full flex flex-col justify-end px-5 py-4 text-white drop-shadow">
                <p class="text-xs uppercase tracking-wide opacity-85">{tpl.domainLabel}</p>
                <h3 class="text-lg font-semibold leading-tight">{tpl.name}</h3>
              </div>
            </div>
            <div class="p-5 flex-1 flex flex-col gap-3">
              <p class="text-sm text-slate-600 dark:text-slate-300 leading-relaxed line-clamp-3">{tpl.description}</p>
              <div class="mt-auto flex gap-2">
                <a
                  class="inline-flex items-center justify-center rounded-lg border border-slate-300 dark:border-slate-700 px-3 py-2 text-sm text-slate-800 dark:text-slate-100 hover:bg-slate-50 dark:hover:bg-slate-800 transition"
                  href={tpl.previewUrl}
                  target="_blank"
                  rel="noreferrer"
                >
                  {translate('preview')}
                </a>
                {tpl.locked ? (
                  <a
                    class="inline-flex items-center justify-center rounded-lg bg-slate-200 text-slate-700 px-3 py-2 text-sm font-semibold shadow-sm hover:bg-slate-300 transition dark:bg-slate-800 dark:text-slate-100 dark:hover:bg-slate-700"
                    href={buildUpgradeUrl()}
                    title={labels.tooltips.advancedLocked[locale as 'fr' | 'en' | 'de' | 'it']}
                  >
                    {labels.upgradeCta[locale as 'fr' | 'en' | 'de' | 'it']}
                  </a>
                ) : (
                  <a
                    class="inline-flex items-center justify-center rounded-lg bg-slate-900 text-white px-3 py-2 text-sm font-semibold shadow-sm hover:bg-slate-800 transition"
                    href={buildSelectUrl(tpl.id)}
                  >
                    {translate('select')}
                  </a>
                )}
              </div>
            </div>
          </article>
        ))}
      </div>
    )}
  </div>
</Layout>
